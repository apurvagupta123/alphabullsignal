---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('./blog/*.md');

// Classify each post
function classify(post: any): 'morning' | 'evening' | null {
  const tags: string[] = post.frontmatter.tags || [];
  const file: string = post.file || '';
  const title: string = (post.frontmatter.title || '').toLowerCase();

  if (
    tags.some((t: string) => t.toLowerCase().includes('morning')) ||
    file.includes('morning') ||
    title.includes('morning')
  ) return 'morning';

  if (
    tags.some((t: string) => ['market briefing','indian markets','nifty','india market'].some(k => t.toLowerCase().includes(k))) ||
    file.includes('india-market-briefing') ||
    title.includes('briefing') ||
    title.includes('evening')
  ) return 'evening';

  return null;
}

const briefings = allPosts
  .map((p: any) => ({ post: p, type: classify(p) }))
  .filter(({ type }) => type !== null)
  .sort((a: any, b: any) =>
    new Date(b.post.frontmatter.date).getTime() - new Date(a.post.frontmatter.date).getTime()
  );

// Group by date
const byDate: Record<string, typeof briefings> = {};
for (const item of briefings) {
  const d = item.post.frontmatter.date;
  if (!byDate[d]) byDate[d] = [];
  byDate[d].push(item);
}

// Sort dates descending
const dates = Object.keys(byDate).sort((a, b) => new Date(b).getTime() - new Date(a).getTime());

function formatDate(d: string) {
  return new Date(d + 'T00:00:00').toLocaleDateString('en-IN', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
  });
}

function slugFromFile(file: string) {
  const match = file.match(/blog\/(.+)\.md$/);
  return match ? `/blog/${match[1]}` : '#';
}
---

<BaseLayout title="Daily Briefing">
  <section class="briefing-page">
    <div class="briefing-header reveal">
      <div class="briefing-eyebrow">MARKET INTELLIGENCE</div>
      <h1 class="briefing-title">Daily Briefing</h1>
      <p class="briefing-subtitle">Morning global recap & evening India session — in one place</p>
    </div>

    <div class="briefing-timeline">
      {dates.map((date) => (
        <div class="timeline-day reveal">
          <div class="timeline-date-label">
            <span class="tl-date">{formatDate(date)}</span>
          </div>
          <div class="timeline-entries">
            {byDate[date]
              .sort((a: any, b: any) => a.type === 'morning' ? -1 : 1)
              .map(({ post, type }: any) => (
                <a href={slugFromFile(post.file)} class={`timeline-card tl-${type}`}>
                  <div class="tl-icon">{type === 'morning' ? '🌅' : '🌆'}</div>
                  <div class="tl-body">
                    <div class="tl-label">{type === 'morning' ? 'Morning Watch' : 'Evening Briefing'}</div>
                    <div class="tl-title">{post.frontmatter.title}</div>
                    {post.frontmatter.excerpt && (
                      <div class="tl-excerpt">{post.frontmatter.excerpt}</div>
                    )}
                  </div>
                  {post.frontmatter.image && (
                    <img class="tl-thumb" src={post.frontmatter.image} alt="" loading="lazy" />
                  )}
                  <div class="tl-arrow">→</div>
                </a>
              ))
            }
          </div>
        </div>
      ))}

      {dates.length === 0 && (
        <div class="briefing-empty">
          <p>No briefings published yet. Check back after the first morning or evening summary runs.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .briefing-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  /* ── Header ── */
  .briefing-header {
    text-align: center;
    margin-bottom: 56px;
  }
  .briefing-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    color: var(--gold, #d4a940);
    margin-bottom: 12px;
    opacity: 0.8;
  }
  .briefing-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 14px;
    line-height: 1.15;
  }
  .briefing-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    margin: 0;
  }

  /* ── Timeline ── */
  .briefing-timeline {
    position: relative;
    padding-left: 0;
  }

  /* Vertical line */
  .briefing-timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, rgba(212,169,64,0.4), rgba(212,169,64,0.05));
    pointer-events: none;
  }

  /* ── Day block ── */
  .timeline-day {
    margin-bottom: 40px;
    padding-left: 52px;
    position: relative;
  }

  /* Dot on the line */
  .timeline-day::before {
    content: '';
    position: absolute;
    left: 14px;
    top: 6px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--gold, #d4a940);
    box-shadow: 0 0 10px rgba(212,169,64,0.45);
  }

  .timeline-date-label {
    margin-bottom: 14px;
  }
  .tl-date {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gold, #d4a940);
    text-transform: uppercase;
  }

  .timeline-entries {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Card ── */
  .timeline-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
    border-radius: 12px;
    border: 1px solid rgba(212,169,64,0.12);
    background: rgba(255,255,255,0.03);
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .timeline-card:hover {
    background: rgba(212,169,64,0.07);
    border-color: rgba(212,169,64,0.3);
    transform: translateX(3px);
  }

  .tl-morning { border-left: 3px solid rgba(253,186,64,0.6); }
  .tl-evening { border-left: 3px solid rgba(99,102,241,0.5); }

  .tl-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .tl-body {
    flex: 1;
    min-width: 0;
  }
  .tl-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }
  .tl-morning .tl-label { color: #fbbf24; }
  .tl-evening .tl-label { color: #a5b4fc; }

  .tl-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.02rem;
    font-weight: 600;
    color: #f0e8d0;
    line-height: 1.35;
    margin-bottom: 6px;
  }
  .tl-excerpt {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tl-thumb {
    width: 72px;
    height: 56px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .tl-arrow {
    color: rgba(212,169,64,0.4);
    font-size: 1.1rem;
    align-self: center;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .timeline-card:hover .tl-arrow {
    color: var(--gold, #d4a940);
    transform: translateX(3px);
  }

  /* ── Empty state ── */
  .briefing-empty {
    text-align: center;
    padding: 60px 0;
    color: rgba(255,255,255,0.35);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
  }

  /* ── Reveal animation (matches site pattern) ── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 600px) {
    .briefing-page { padding: 32px 16px 60px; }
    .tl-thumb { display: none; }
    .briefing-timeline::before { left: 12px; }
    .timeline-day { padding-left: 36px; }
    .timeline-day::before { left: 6px; }
  }
</style>
