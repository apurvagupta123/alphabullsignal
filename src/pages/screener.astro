---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="India Stock Snapshot">

<section class="content-section" style="margin-top:48px">
  <div class="section-head">
    <h2 class="section-title">🔍 India Stock Snapshot</h2>
    <span class="section-live">NSE</span>
  </div>
  <p style="color:var(--text-muted);font-size:13px;margin-bottom:20px">
    Top 50 NSE stocks — price, day change, and 52-week position. Refreshes twice daily.
  </p>

  <!-- Controls -->
  <div class="snp-controls">
    <div class="snp-filters" id="sectorFilters">
      <button class="snp-filter active" data-sector="all">All</button>
      <button class="snp-filter" data-sector="IT">IT</button>
      <button class="snp-filter" data-sector="Banking">Banking</button>
      <button class="snp-filter" data-sector="FMCG">FMCG</button>
      <button class="snp-filter" data-sector="Auto">Auto</button>
      <button class="snp-filter" data-sector="Pharma">Pharma</button>
      <button class="snp-filter" data-sector="Energy">Energy</button>
      <button class="snp-filter" data-sector="Infra">Infra</button>
    </div>
    <div class="snp-sort-row">
      <label class="snp-label">Sort by:</label>
      <select class="snp-sort" id="snpSort">
        <option value="gainers">Top Gainers</option>
        <option value="losers">Top Losers</option>
        <option value="name">Name A–Z</option>
        <option value="price_high">Price ↓</option>
        <option value="price_low">Price ↑</option>
      </select>
    </div>
  </div>

  <div id="snpLoading" class="snp-loading">Loading stock data…</div>
  <div id="snpGrid" style="display:none"></div>
  <div id="snpEmpty" style="display:none;text-align:center;padding:48px;color:var(--text-muted)">No stocks match this filter.</div>
</section>

</BaseLayout>

<script>
// Sector mapping
const SECTORS = {
  'TCS':'IT','INFY':'IT','WIPRO':'IT','HCLTECH':'IT','TECHM':'IT',
  'RELIANCE':'Energy','ONGC':'Energy','COALINDIA':'Energy','NTPC':'Energy','POWERGRID':'Energy',
  'HDFCBANK':'Banking','ICICIBANK':'Banking','KOTAKBANK':'Banking','SBIN':'Banking','AXISBANK':'Banking',
  'BAJFINANCE':'Banking','BAJAJFINSV':'Banking','HDFCLIFE':'Banking','SBILIFE':'Banking',
  'HINDUNILVR':'FMCG','ITC':'FMCG','NESTLEIND':'FMCG','BRITANNIA':'FMCG','DABUR':'FMCG',
  'MARUTI':'Auto','TATAMOTORS':'Auto','BAJAJ-AUTO':'Auto','EICHERMOT':'Auto','HEROMOTOCO':'Auto','M&M':'Auto',
  'SUNPHARMA':'Pharma','DRREDDY':'Pharma','CIPLA':'Pharma','DIVISLAB':'Pharma','APOLLOHOSP':'Pharma',
  'LT':'Infra','ADANIENT':'Infra','ADANIPORTS':'Infra','TATASTEEL':'Infra','JSWSTEEL':'Infra',
  'BHARTIARTL':'Telecom','TITAN':'Consumer','ASIANPAINT':'Consumer','ULTRACEMCO':'Infra',
};

let allStocks   = [];
let activeSector = 'all';
let activeSort   = 'gainers';

function fmt(n) {
  if (!n && n !== 0) return '—';
  return Number(n).toLocaleString('en-IN', { maximumFractionDigits: 2 });
}
function pctColor(p) {
  if (!p && p !== 0) return 'var(--text-muted)';
  return Number(p) > 0 ? '#22c55e' : Number(p) < 0 ? '#ef4444' : 'var(--text-muted)';
}
function pctArrow(p) {
  if (!p && p !== 0) return '';
  return Number(p) > 0 ? '▲' : Number(p) < 0 ? '▼' : '';
}

// 52-week position bar (0–100%)
function w52Bar(price, low, high) {
  if (!price || !low || !high || high <= low) return '';
  const pct = Math.max(0, Math.min(100, ((price - low) / (high - low)) * 100));
  const color = pct > 70 ? '#22c55e' : pct > 30 ? '#f59e0b' : '#ef4444';
  return `
    <div class="snp-52">
      <span class="snp-52-lbl">52W L ₹${fmt(low)}</span>
      <div class="snp-52-track">
        <div class="snp-52-fill" style="width:${pct.toFixed(1)}%;background:${color}"></div>
        <div class="snp-52-pin" style="left:${pct.toFixed(1)}%;background:${color}"></div>
      </div>
      <span class="snp-52-lbl">H ₹${fmt(high)}</span>
    </div>`;
}

function renderCards(stocks) {
  const grid = document.getElementById('snpGrid');
  const empty = document.getElementById('snpEmpty');
  if (!stocks.length) {
    grid.style.display  = 'none';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  grid.style.display  = 'grid';

  grid.innerHTML = stocks.map(s => {
    const sym    = s.symbol.replace('.NS','').replace('.BO','');
    const chg    = parseFloat(s.changePercent) || 0;
    const color  = pctColor(chg);
    const arrow  = pctArrow(chg);
    const sector = SECTORS[sym] || 'Other';

    return `<div class="snp-card">
      <div class="snp-card-top">
        <div>
          <div class="snp-sym">${sym}</div>
          <div class="snp-name">${s.name || sym}</div>
        </div>
        <span class="snp-sector-tag">${sector}</span>
      </div>
      <div class="snp-price-row">
        <span class="snp-price">₹${fmt(s.price)}</span>
        <span class="snp-chg" style="color:${color}">${arrow} ${Math.abs(chg).toFixed(2)}%</span>
      </div>
      ${w52Bar(s.price, s.week52Low, s.week52High)}
    </div>`;
  }).join('');
}

function applyFiltersAndSort() {
  let stocks = [...allStocks];

  // Sector filter
  if (activeSector !== 'all') {
    stocks = stocks.filter(s => {
      const sym = s.symbol.replace('.NS','').replace('.BO','');
      return (SECTORS[sym] || 'Other') === activeSector;
    });
  }

  // Sort
  stocks.sort((a, b) => {
    const ca = parseFloat(a.changePercent) || 0;
    const cb = parseFloat(b.changePercent) || 0;
    if (activeSort === 'gainers')    return cb - ca;
    if (activeSort === 'losers')     return ca - cb;
    if (activeSort === 'name')       return (a.name||a.symbol).localeCompare(b.name||b.symbol);
    if (activeSort === 'price_high') return (parseFloat(b.price)||0) - (parseFloat(a.price)||0);
    if (activeSort === 'price_low')  return (parseFloat(a.price)||0) - (parseFloat(b.price)||0);
    return 0;
  });

  renderCards(stocks);
}

async function loadData() {
  try {
    const r    = await fetch('/data/quotes.json');
    const data = await r.json();
    allStocks  = data.quotes || [];

    document.getElementById('snpLoading').style.display = 'none';
    applyFiltersAndSort();
  } catch (e) {
    document.getElementById('snpLoading').innerHTML =
      `<div style="text-align:center;padding:48px;color:var(--text-muted)">
        <div style="font-size:28px;margin-bottom:12px">⚠️</div>
        <div>Could not load stock data — try refreshing.</div>
       </div>`;
  }
}

// Sector filter buttons
document.querySelectorAll('.snp-filter').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.snp-filter').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeSector = btn.dataset.sector;
    applyFiltersAndSort();
  });
});

// Sort dropdown
document.getElementById('snpSort').addEventListener('change', e => {
  activeSort = e.target.value;
  applyFiltersAndSort();
});

loadData();
</script>

<style>
.snp-controls {
  display:flex; justify-content:space-between; align-items:center;
  gap:12px; flex-wrap:wrap; margin-bottom:20px;
}
.snp-filters   { display:flex; gap:6px; flex-wrap:wrap; }
.snp-filter    {
  padding:5px 12px; border-radius:20px; border:1px solid var(--border);
  background:transparent; color:var(--text-muted); font-size:11px; font-weight:600;
  cursor:pointer; transition:all 0.2s;
}
.snp-filter.active, .snp-filter:hover {
  background:var(--gold); color:#000; border-color:var(--gold);
}
.snp-sort-row  { display:flex; align-items:center; gap:8px; }
.snp-label     { font-size:12px; color:var(--text-muted); white-space:nowrap; }
.snp-sort      {
  background:var(--navy-2); border:1px solid var(--border); color:var(--text);
  font-size:12px; padding:5px 10px; border-radius:8px; cursor:pointer;
}

.snp-loading   { text-align:center; padding:48px; color:var(--text-muted); font-size:13px; }

#snpGrid {
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap:12px;
}

.snp-card {
  background:var(--navy-2); border:1px solid var(--border); border-radius:10px;
  padding:16px; transition:border-color 0.2s, transform 0.15s;
}
.snp-card:hover { border-color:rgba(212,169,64,0.35); transform:translateY(-2px); }

.snp-card-top  { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px; }
.snp-sym       { font-size:15px; font-weight:800; color:var(--gold); }
.snp-name      { font-size:11px; color:var(--text-muted); margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:120px; }
.snp-sector-tag {
  font-size:9px; font-weight:700; letter-spacing:0.5px;
  background:rgba(255,255,255,0.05); border:1px solid var(--border);
  color:var(--text-muted); padding:2px 7px; border-radius:10px; white-space:nowrap;
  flex-shrink:0; margin-left:8px;
}

.snp-price-row { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:10px; }
.snp-price     { font-size:18px; font-weight:800; color:#fff; }
.snp-chg       { font-size:13px; font-weight:700; }

/* 52W bar */
.snp-52        { display:flex; align-items:center; gap:6px; }
.snp-52-lbl    { font-size:9px; color:var(--text-muted); white-space:nowrap; flex-shrink:0; }
.snp-52-track  {
  flex:1; height:4px; background:rgba(255,255,255,0.08);
  border-radius:2px; position:relative;
}
.snp-52-fill   { height:100%; border-radius:2px; transition:width 0.4s; }
.snp-52-pin    {
  position:absolute; top:50%; transform:translate(-50%,-50%);
  width:8px; height:8px; border-radius:50%; border:2px solid #0a0f1e;
}

@media (max-width:480px) {
  #snpGrid { grid-template-columns:1fr 1fr; }
  .snp-controls { flex-direction:column; align-items:flex-start; }
}
</style>
