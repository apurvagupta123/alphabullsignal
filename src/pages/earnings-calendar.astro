---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="India Earnings Calendar">
  <section class="content-section" style="margin-top:48px">
    <div class="section-head">
      <h2 class="section-title">📊 India Earnings Calendar</h2>
      <span class="section-live">NSE</span>
    </div>
    <p style="color:var(--text-muted);font-size:13px;margin-bottom:24px">
      Upcoming quarterly result dates for top NSE-listed companies. Data refreshes twice daily via GitHub Actions.
    </p>

    <!-- Results Season Banner -->
    <div class="results-season-banner" id="seasonBanner"></div>

    <!-- Tabs -->
    <div class="tabs-row" style="margin-bottom:20px">
      <button class="ipo-tab active" id="tabUpcoming">Upcoming Results</button>
      <button class="ipo-tab" id="tabSeason">Results Seasons</button>
    </div>

    <!-- Upcoming Results (from JSON) -->
    <div id="panelUpcoming">
      <div class="ec-loading" id="earningsLoading">Loading upcoming results…</div>
      <div id="earningsTable" style="display:none"></div>
    </div>

    <!-- Results Seasons (hardcoded India schedule) -->
    <div id="panelSeason" style="display:none">
      <div class="season-grid">
        <div class="season-card">
          <div class="season-icon">🌱</div>
          <div class="season-q">Q1 FY27 Results</div>
          <div class="season-period">April – June 2026</div>
          <div class="season-window">📅 Results announced: <strong>July – August 2026</strong></div>
          <div class="season-note">Companies report within 45 days of quarter end. TCS, Infosys, HDFC Bank typically among the first.</div>
        </div>
        <div class="season-card">
          <div class="season-icon">🌧️</div>
          <div class="season-q">Q2 FY27 Results</div>
          <div class="season-period">July – September 2026</div>
          <div class="season-window">📅 Results announced: <strong>October – November 2026</strong></div>
          <div class="season-note">Coincides with Diwali season. Strong results + festive mood historically fuel Nifty rallies in October.</div>
        </div>
        <div class="season-card">
          <div class="season-icon">❄️</div>
          <div class="season-q">Q3 FY27 Results</div>
          <div class="season-period">October – December 2026</div>
          <div class="season-window">📅 Results announced: <strong>January – February 2027</strong></div>
          <div class="season-note">Winter quarter — FMCG and consumer durables see festive demand boost. IT companies report in mid-January.</div>
        </div>
        <div class="season-card">
          <div class="season-icon">🌸</div>
          <div class="season-q">Q4 FY27 Results</div>
          <div class="season-period">January – March 2027</div>
          <div class="season-window">📅 Results announced: <strong>April – May 2027</strong></div>
          <div class="season-note">Full-year results season. Management guidance for FY28 closely watched. Often the most market-moving quarter.</div>
        </div>
      </div>

      <div class="ec-tip">
        <strong style="color:var(--gold)">💡 How to use this:</strong>
        Stock prices often move 3–8% on results day. Buying before results is speculative; professionals wait for results + management commentary before acting. Watch for "beat/miss vs. analyst estimates" — not just profit growth.
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Tab toggle ────────────────────────────────────────────────────────────
  document.getElementById('tabUpcoming').addEventListener('click', () => {
    document.getElementById('panelUpcoming').style.display = 'block';
    document.getElementById('panelSeason').style.display   = 'none';
    document.getElementById('tabUpcoming').classList.add('active');
    document.getElementById('tabSeason').classList.remove('active');
  });
  document.getElementById('tabSeason').addEventListener('click', () => {
    document.getElementById('panelUpcoming').style.display = 'none';
    document.getElementById('panelSeason').style.display   = 'block';
    document.getElementById('tabSeason').classList.add('active');
    document.getElementById('tabUpcoming').classList.remove('active');
  });

  // ── Results season banner ────────────────────────────────────────────────
  const today = new Date();
  const month = today.getMonth() + 1; // 1-12
  let seasonMsg = '';
  if (month === 7 || month === 8) {
    seasonMsg = '🌱 <strong>Q1 FY27 Results Season is LIVE</strong> — Top NSE companies reporting July–August 2026. Expect high volatility on result days.';
  } else if (month === 10 || month === 11) {
    seasonMsg = '🌧️ <strong>Q2 FY27 Results Season is LIVE</strong> — October–November results + Diwali rally combo. Watch for earnings surprises.';
  } else if (month === 1 || month === 2) {
    seasonMsg = '❄️ <strong>Q3 FY27 Results Season is LIVE</strong> — IT companies lead January; banks and FMCG follow in February.';
  } else if (month === 4 || month === 5) {
    seasonMsg = '🌸 <strong>Q4 FY27 Results Season is LIVE</strong> — Full-year results + FY28 guidance. Most important quarter for investors.';
  } else {
    seasonMsg = '📅 Between results seasons. Next results season starts in ' +
      (month <= 6 ? 'July 2026 (Q1 FY27)' : month <= 9 ? 'October 2026 (Q2 FY27)' : 'January 2027 (Q3 FY27)');
  }
  document.getElementById('seasonBanner').innerHTML = seasonMsg;
  document.getElementById('seasonBanner').style.display = seasonMsg ? 'block' : 'none';

  // ── Load earnings from JSON ──────────────────────────────────────────────
  async function loadEarnings() {
    const loading = document.getElementById('earningsLoading');
    const table   = document.getElementById('earningsTable');

    try {
      const r    = await fetch('/data/earnings.json');
      const data = await r.json();
      const entries = (data.earnings || []).filter(e => e.earningsDate >= new Date().toISOString().split('T')[0]);

      if (!entries.length) {
        loading.innerHTML = `
          <div style="text-align:center;padding:40px 20px;color:var(--text-muted)">
            <div style="font-size:32px;margin-bottom:12px">📭</div>
            <div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:8px">No upcoming result dates found</div>
            <div style="font-size:13px;line-height:1.6">
              NSE companies typically announce result dates 2–3 weeks before reporting.<br>
              Check back closer to the results season (July for Q1, October for Q2).
            </div>
            <div style="margin-top:16px;font-size:11px;color:var(--text-muted)">
              Last updated: ${new Date(data.lastUpdated).toLocaleString('en-IN', {timeZone:'Asia/Kolkata'})} IST
            </div>
          </div>`;
        return;
      }

      // Group by date
      const byDate = {};
      entries.forEach(e => {
        if (!byDate[e.earningsDate]) byDate[e.earningsDate] = [];
        byDate[e.earningsDate].push(e);
      });

      const companyNames = {
        'TCS':'Tata Consultancy Services','INFY':'Infosys','WIPRO':'Wipro','HCLTECH':'HCL Technologies','TECHM':'Tech Mahindra',
        'RELIANCE':'Reliance Industries','HDFCBANK':'HDFC Bank','ICICIBANK':'ICICI Bank','KOTAKBANK':'Kotak Mahindra Bank',
        'SBIN':'State Bank of India','AXISBANK':'Axis Bank','BAJFINANCE':'Bajaj Finance','BAJAJFINSV':'Bajaj Finserv',
        'LT':'Larsen & Toubro','BHARTIARTL':'Bharti Airtel','SUNPHARMA':'Sun Pharma','DRREDDY':'Dr. Reddy\'s',
        'CIPLA':'Cipla','DIVISLAB':'Divi\'s Laboratories','HINDUNILVR':'Hindustan Unilever','ITC':'ITC Limited',
        'NESTLEIND':'Nestle India','BRITANNIA':'Britannia Industries','MARUTI':'Maruti Suzuki',
        'TMCV':'Tata Motors','TITAN':'Titan Company','ADANIENT':'Adani Enterprises',
        'ASIANPAINT':'Asian Paints','NTPC':'NTPC Limited','ONGC':'ONGC','COALINDIA':'Coal India','TATASTEEL':'Tata Steel',
      };

      table.innerHTML = Object.entries(byDate).sort().map(([date, companies]) => {
        const d       = new Date(date);
        const isToday = date === new Date().toISOString().split('T')[0];
        const dayName = d.toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
        return `
          <div class="ec-day" style="${isToday ? 'border-color:var(--gold)' : ''}">
            <div class="ec-day-header">
              <span class="ec-day-name">${dayName} ${isToday ? '<span class="econ-today-badge">TODAY</span>' : ''}</span>
              <span class="ec-day-count">${companies.length} result${companies.length > 1 ? 's' : ''}</span>
            </div>
            <div class="ec-table-wrap">
              <table class="ipo-table">
                <thead><tr><th>Company</th><th>Symbol</th><th>Sector</th></tr></thead>
                <tbody>
                  ${companies.map(c => `
                    <tr>
                      <td class="ipo-company">${companyNames[c.name] || c.name}</td>
                      <td class="ipo-sym">
                        <a href="/company/${c.symbol.replace('.NS','').replace('.BO','').toLowerCase()}.ns" class="ipo-link">
                          ${c.name}
                        </a>
                      </td>
                      <td style="font-size:11px;color:var(--text-muted)">NSE</td>
                    </tr>`).join('')}
                </tbody>
              </table>
            </div>
          </div>`;
      }).join('');

      loading.style.display = 'none';
      table.style.display   = 'block';
    } catch (err) {
      loading.innerHTML = `<div style="text-align:center;padding:32px;color:var(--text-muted)">Could not load data — try refreshing.</div>`;
    }
  }

  loadEarnings();
</script>

<style>
.results-season-banner {
  background:rgba(212,169,64,0.08); border:1px solid rgba(212,169,64,0.25);
  border-radius:10px; padding:14px 18px; font-size:13px; color:var(--text);
  line-height:1.6; margin-bottom:20px;
}

.season-grid {
  display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:24px;
}
.season-card {
  background:var(--navy-2); border:1px solid var(--border); border-radius:12px;
  padding:20px; transition:border-color 0.2s;
}
.season-card:hover { border-color:rgba(212,169,64,0.3); }
.season-icon   { font-size:28px; margin-bottom:10px; }
.season-q      { font-size:15px; font-weight:700; color:#fff; margin-bottom:2px; }
.season-period { font-size:12px; color:var(--gold); font-weight:600; margin-bottom:10px; }
.season-window { font-size:12px; color:var(--text-muted); margin-bottom:8px; }
.season-window strong { color:var(--text); }
.season-note   { font-size:12px; color:var(--text-muted); line-height:1.6; }

.ec-tip {
  background:rgba(212,169,64,0.05); border:1px solid rgba(212,169,64,0.15);
  border-radius:10px; padding:16px 18px; font-size:13px; color:var(--text-muted); line-height:1.7;
}
.ec-day {
  background:var(--navy-2); border:1px solid var(--border); border-radius:10px;
  margin-bottom:16px; overflow:hidden;
}
.ec-day-header {
  display:flex; justify-content:space-between; align-items:center;
  padding:12px 16px; border-bottom:1px solid var(--border); background:rgba(0,0,0,0.1);
}
.ec-day-name  { font-size:13px; font-weight:700; color:#fff; }
.ec-day-count { font-size:11px; color:var(--gold); font-weight:600; background:rgba(212,169,64,0.1); padding:2px 8px; border-radius:10px; }
.ec-table-wrap { overflow-x:auto; }
.ec-loading   { text-align:center; padding:40px; color:var(--text-muted); }
.econ-today-badge {
  display:inline-block; background:var(--gold); color:#000;
  font-size:9px; font-weight:800; letter-spacing:0.5px; border-radius:3px;
  padding:1px 5px; margin-left:8px; vertical-align:middle;
}

@media (max-width:640px) {
  .season-grid { grid-template-columns:1fr; }
}
</style>
