---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---
<BaseLayout title="Business Intelligence, Daily">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          LIVE MARKET DATA
        </div>
        <h1 class="hero-title">
          Business Intelligence,<br />
          <span class="hero-accent">Daily.</span>
        </h1>
        <p class="hero-desc">
          Track markets, discover company insights, and stay ahead with<br />
          curated financial news — all in one place.
        </p>
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hs-num">500+</span>
            <span class="hs-label">STOCKS TRACKED</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Daily</span>
            <span class="hs-label">NEWS UPDATES</span>
          </div>
          <div class="hs-divider"></div>
          <div class="hero-stat">
            <span class="hs-num">Real-Time</span>
            <span class="hs-label">MARKET DATA</span>
          </div>
        </div>
        <div class="hero-actions">
          <button class="btn-primary" onclick="document.getElementById('markets').scrollIntoView({behavior:'smooth'})">Explore Markets →</button>
          <button class="btn-outline" onclick="document.getElementById('news').scrollIntoView({behavior:'smooth'})">Latest News</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Indices Bar ──────────────────────────────────── -->
  <section class="indices-section">
    <div class="indices-grid" id="indicesBar">
      <div class="idx-card skeleton" id="idx-SPY">
        <span class="idx-name">S&P 500</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-QQQ">
        <span class="idx-name">NASDAQ</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-DIA">
        <span class="idx-name">DOW JONES</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-IWM">
        <span class="idx-name">RUSSELL 2000</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
    </div>
  </section>

  <!-- ── Fear & Greed + Sector Heatmap ───────────────── -->
  <div class="fg-heatmap-row">

    <!-- Fear & Greed -->
    <div class="content-section fg-section">
      <div class="section-head">
        <h2 class="section-title">😱 Fear &amp; Greed Index</h2>
      </div>
      <div class="fg-widget" id="fgWidget">
        <div class="fg-gauge-wrap">
          <svg class="fg-gauge" viewBox="0 0 200 110" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="fgGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%"   stop-color="#ef4444"/>
                <stop offset="25%"  stop-color="#f97316"/>
                <stop offset="50%"  stop-color="#eab308"/>
                <stop offset="75%"  stop-color="#84cc16"/>
                <stop offset="100%" stop-color="#22c55e"/>
              </linearGradient>
            </defs>
            <path d="M 10 100 A 90 90 0 0 1 190 100" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="16" stroke-linecap="round"/>
            <path d="M 10 100 A 90 90 0 0 1 190 100" fill="none" stroke="url(#fgGrad)" stroke-width="16" stroke-linecap="round"/>
            <line id="fgNeedle" x1="100" y1="100" x2="100" y2="20" stroke="#fff" stroke-width="3" stroke-linecap="round" transform="rotate(-90 100 100)"/>
            <circle cx="100" cy="100" r="5" fill="#fff"/>
          </svg>
          <div class="fg-center">
            <div class="fg-value" id="fgValue">—</div>
            <div class="fg-label" id="fgLabel">Loading…</div>
          </div>
        </div>
        <div class="fg-scale">
          <span style="color:#ef4444">Fear</span>
          <span style="color:#eab308">Neutral</span>
          <span style="color:#22c55e">Greed</span>
        </div>
        <div class="fg-prev" id="fgPrev"></div>
      </div>
    </div>

    <!-- Sector Heatmap -->
    <div class="content-section heatmap-section">
      <div class="section-head">
        <h2 class="section-title">🌡️ Sector Heatmap</h2>
        <span class="section-live">LIVE</span>
      </div>
      <div class="heatmap-grid" id="heatmapGrid">
        {[
          {sym:'XLK',name:'Technology'},
          {sym:'XLF',name:'Finance'},
          {sym:'XLE',name:'Energy'},
          {sym:'XLV',name:'Health Care'},
          {sym:'XLY',name:'Consumer Disc.'},
          {sym:'XLP',name:'Consumer Staples'},
          {sym:'XLI',name:'Industrials'},
          {sym:'XLU',name:'Utilities'},
          {sym:'XLB',name:'Materials'},
          {sym:'XLRE',name:'Real Estate'},
        ].map(s => (
          <div class="hm-cell skeleton" id={`hm-${s.sym}`}>
            <span class="hm-name">{s.name}</span>
            <span class="hm-pct" id={`hmp-${s.sym}`}>—</span>
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- ── Today's Markets ─────────────────────────────── -->
  <section class="content-section" id="markets">
    <div class="section-head">
      <h2 class="section-title">Today's Markets</h2>
      <a href="/" class="section-more">View all markets →</a>
    </div>
    <div class="markets-grid" id="marketsGrid">
      {['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','NFLX'].map((sym) => (
        <div class="mkt-card" id={`mc-${sym}`}>
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">{sym}</div>
              <div class="mkt-name" id={`mn-${sym}`}>—</div>
            </div>
            <div class="mkt-badge" id={`mb-${sym}`}>—</div>
          </div>
          <div class="mkt-price" id={`mp-${sym}`}>—</div>
          <div class="mkt-chg" id={`mch-${sym}`}>—</div>
          <canvas class="mkt-chart" id={`chart-${sym}`} height="60"></canvas>
        </div>
      ))}
    </div>
  </section>

  <!-- ── News + Spotlight ─────────────────────────────── -->
  <div class="two-col">

    <!-- Business News -->
    <section class="content-section" id="news">
      <div class="section-head">
        <h2 class="section-title">Business News</h2>
      </div>
      <div class="news-list" id="newsList">
        {[1,2,3,4,5,6].map(() => (
          <div class="news-item">
            <div class="news-shimmer news-shimmer-title"></div>
            <div class="news-shimmer news-shimmer-meta"></div>
          </div>
        ))}
      </div>
    </section>

    <!-- Company Spotlight -->
    <section class="content-section">
      <div class="section-head">
        <h2 class="section-title">Company Spotlight</h2>
      </div>
      <div class="spotlight-box">
        <div class="spotlight-search">
          <input id="slInput" type="text" class="sl-input" placeholder="Enter ticker symbol (e.g. AAPL)" />
          <button id="slBtn" class="sl-btn">Search</button>
        </div>
        <div id="slResult">
          <p class="sl-hint">Enter a stock ticker above to see company details, live price, and 3-month chart.</p>
        </div>
      </div>
    </section>

  </div>

  <!-- ── Blog Posts ───────────────────────────────────── -->
  {sorted.length > 0 && (
    <section class="content-section">
      <div class="section-head">
        <h2 class="section-title">From the Ledger</h2>
      </div>
      <div class="posts-grid">
        {sorted.map((post: any) => (
          <a href={post.url} class="post-card">
            <div class="pc-date">
              {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </div>
            <h3 class="pc-title">{post.frontmatter.title}</h3>
            <p class="pc-desc">{post.frontmatter.description}</p>
            <span class="pc-read">Read more →</span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<script>
  const P = 'https://api.allorigins.win/get?url=';

  async function yf(syms: string, fields: string) {
    const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${syms}&fields=${fields}`;
    const r = await fetch(P + encodeURIComponent(url));
    const w = await r.json();
    return JSON.parse(w.contents)?.quoteResponse?.result || [];
  }

  async function yfChart(sym: string) {
    const url = `https://query1.finance.yahoo.com/v8/finance/chart/${sym}?range=1mo&interval=1d`;
    const r = await fetch(P + encodeURIComponent(url));
    const w = await r.json();
    return JSON.parse(w.contents)?.chart?.result?.[0] || null;
  }

  // ── Indices ───────────────────────────────────────────────────────────
  async function loadIndices() {
    const map: Record<string, string> = { SPY: 'S&P 500', QQQ: 'NASDAQ', DIA: 'DOW JONES', IWM: 'RUSSELL 2000' };
    try {
      const quotes = await yf(Object.keys(map).join(','), 'symbol,regularMarketPrice,regularMarketChange,regularMarketChangePercent');
      quotes.forEach((q: any) => {
        const el = document.getElementById(`idx-${q.symbol}`);
        if (!el) return;
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        el.classList.remove('skeleton');
        el.classList.add(up ? 'up' : 'dn');
        el.querySelector('.idx-price')!.textContent = `${q.regularMarketPrice?.toFixed(2)}`;
        el.querySelector('.idx-chg')!.textContent   = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(2)}%`;
      });
    } catch {}
  }

  // ── Markets Grid ──────────────────────────────────────────────────────
  async function loadMarkets() {
    const syms = ['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','NFLX'];
    try {
      const quotes = await yf(syms.join(','), 'symbol,shortName,regularMarketPrice,regularMarketChange,regularMarketChangePercent');
      for (const q of quotes) {
        const chg = q.regularMarketChange ?? 0;
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = chg >= 0;
        const color = up ? '#22c55e' : '#ef4444';
        const sign  = up ? '+' : '';

        const nameEl  = document.getElementById(`mn-${q.symbol}`);
        const badgeEl = document.getElementById(`mb-${q.symbol}`);
        const priceEl = document.getElementById(`mp-${q.symbol}`);
        const chgEl   = document.getElementById(`mch-${q.symbol}`);
        const card    = document.getElementById(`mc-${q.symbol}`);

        if (nameEl)  nameEl.textContent  = q.shortName || '';
        if (priceEl) priceEl.textContent = `$${q.regularMarketPrice?.toFixed(2)}`;
        if (chgEl) {
          chgEl.textContent = `${up ? '▲' : '▼'} $${Math.abs(chg).toFixed(2)} ${sign}${pct.toFixed(2)}%`;
          (chgEl as HTMLElement).style.color = color;
        }
        if (badgeEl) {
          badgeEl.textContent = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(2)}%`;
          badgeEl.classList.add(up ? 'badge-up' : 'badge-dn');
        }
        if (card) card.classList.add(up ? 'up' : 'dn');

        // Sparkline
        try {
          const cd = await yfChart(q.symbol);
          const closes = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
          if (closes.length > 1) {
            const canvas = document.getElementById(`chart-${q.symbol}`) as HTMLCanvasElement;
            new (window as any).Chart(canvas, {
              type: 'line',
              data: {
                labels: closes.map((_: any, i: number) => i),
                datasets: [{ data: closes, borderColor: color, borderWidth: 2, pointRadius: 0,
                  fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }]
              },
              options: { animation: false, responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false }, tooltip: { enabled: false } },
                scales: { x: { display: false }, y: { display: false } } }
            });
          }
        } catch {}
      }
    } catch {}
  }

  // ── News ──────────────────────────────────────────────────────────────
  async function loadNews() {
    const list = document.getElementById('newsList');
    if (!list) return;
    try {
      const rss = 'https://feeds.reuters.com/reuters/businessNews';
      const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=8`);
      const d = await r.json();
      const items = d?.items || [];
      if (!items.length) throw new Error('empty');
      list.innerHTML = items.map((item: any) => {
        const date = new Date(item.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener">
          <div class="ni-title">${item.title}</div>
          <div class="ni-meta">${item.author || 'Reuters'} · ${date}</div>
        </a>`;
      }).join('');
    } catch {
      const fallback = [
        ['Fed holds rates as inflation nears 2% target', 'Reuters', '2h ago'],
        ['S&P 500 hits record high on strong earnings season', 'Bloomberg', '4h ago'],
        ['Apple unveils new AI features at WWDC', 'CNBC', '5h ago'],
        ['Oil climbs on Middle East supply concerns', 'Reuters', '6h ago'],
        ['Tesla beats delivery estimates, stock surges 8%', 'WSJ', '8h ago'],
        ['Goldman Sachs raises S&P 500 year-end target', 'FT', '10h ago'],
      ];
      list.innerHTML = fallback.map(([t, s, d]) => `<div class="news-item">
        <div class="ni-title">${t}</div>
        <div class="ni-meta">${s} · ${d}</div>
      </div>`).join('');
    }
  }

  // ── Spotlight ─────────────────────────────────────────────────────────
  async function loadSpotlight(sym: string) {
    const result = document.getElementById('slResult');
    if (!result) return;
    result.innerHTML = `<p class="sl-hint">Loading ${sym.toUpperCase()}…</p>`;
    try {
      const s = sym.toUpperCase().trim();
      const [quotes, cd] = await Promise.all([
        yf(s, 'symbol,shortName,longName,regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,fiftyTwoWeekHigh,fiftyTwoWeekLow,averageVolume'),
        yfChart(s)
      ]);
      const q = quotes[0];
      if (!q) throw new Error('not found');
      const chg   = q.regularMarketChange ?? 0;
      const pct   = q.regularMarketChangePercent ?? 0;
      const up    = chg >= 0;
      const color = up ? '#22c55e' : '#ef4444';
      const sign  = up ? '+' : '';
      const mcap  = q.marketCap ? (q.marketCap >= 1e12 ? `$${(q.marketCap/1e12).toFixed(2)}T` : `$${(q.marketCap/1e9).toFixed(1)}B`) : '—';

      result.innerHTML = `
        <div class="sl-company">${q.longName || q.shortName || s}</div>
        <div class="sl-price-row">
          <span class="sl-price" style="color:var(--gold)">$${q.regularMarketPrice?.toFixed(2)}</span>
          <span class="sl-delta" style="color:${color}">${up ? '▲' : '▼'} $${Math.abs(chg).toFixed(2)} (${sign}${pct.toFixed(2)}%)</span>
        </div>
        <div class="sl-stats">
          <div class="sl-stat"><span>Market Cap</span><strong>${mcap}</strong></div>
          <div class="sl-stat"><span>P/E Ratio</span><strong>${q.trailingPE?.toFixed(1) || '—'}</strong></div>
          <div class="sl-stat"><span>52W High</span><strong>$${q.fiftyTwoWeekHigh?.toFixed(2) || '—'}</strong></div>
          <div class="sl-stat"><span>52W Low</span><strong>$${q.fiftyTwoWeekLow?.toFixed(2) || '—'}</strong></div>
          <div class="sl-stat"><span>Avg Volume</span><strong>${q.averageVolume ? (q.averageVolume/1e6).toFixed(1)+'M' : '—'}</strong></div>
        </div>
        <canvas id="slChart" style="height:130px;width:100%"></canvas>
      `;
      const closes    = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
      const timestamps = cd?.timestamp || [];
      if (closes.length > 1) {
        new (window as any).Chart(document.getElementById('slChart') as HTMLCanvasElement, {
          type: 'line',
          data: {
            labels: timestamps.map((t: number) => new Date(t*1000).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })),
            datasets: [{ data: closes, borderColor: color, borderWidth: 2, pointRadius: 0,
              fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }]
          },
          options: { animation: false, responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false },
              tooltip: { callbacks: { label: (ctx: any) => `$${ctx.parsed.y.toFixed(2)}` } } },
            scales: {
              x: { ticks: { color: '#8892a4', maxTicksLimit: 5 }, grid: { color: 'rgba(255,255,255,0.04)' } },
              y: { ticks: { color: '#8892a4', callback: (v: any) => `$${v}` }, grid: { color: 'rgba(255,255,255,0.04)' } }
            }
          }
        });
      }
    } catch {
      result.innerHTML = `<p class="sl-hint" style="color:#ef4444">Ticker "${sym}" not found. Try AAPL, MSFT, TSLA…</p>`;
    }
  }

  document.getElementById('slBtn')?.addEventListener('click', () => {
    const v = (document.getElementById('slInput') as HTMLInputElement).value;
    if (v.trim()) loadSpotlight(v.trim());
  });
  document.getElementById('slInput')?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      const v = (document.getElementById('slInput') as HTMLInputElement).value;
      if (v.trim()) loadSpotlight(v.trim());
    }
  });

  // ── Fear & Greed ─────────────────────────────────────────────
  async function loadFearGreed() {
    try {
      const r = await fetch('https://api.alternative.me/fng/?limit=2');
      const d = await r.json();
      const cur  = d?.data?.[0];
      const prev = d?.data?.[1];
      if (!cur) throw new Error('empty');

      const val   = parseInt(cur.value);
      const label = cur.value_classification;
      const color = val >= 75 ? '#22c55e' : val >= 55 ? '#84cc16' : val >= 45 ? '#eab308' : val >= 25 ? '#f97316' : '#ef4444';

      document.getElementById('fgValue').textContent = val.toString();
      document.getElementById('fgValue').style.color = color;
      document.getElementById('fgLabel').textContent = label;
      document.getElementById('fgLabel').style.color = color;

      // Rotate needle: -90deg = 0 (fear), 0deg = 50 (neutral), +90deg = 100 (greed)
      const angle = (val / 100) * 180 - 90;
      const needle = document.getElementById('fgNeedle');
      if (needle) needle.setAttribute('transform', `rotate(${angle} 100 100)`);

      if (prev) {
        const prevVal = parseInt(prev.value);
        const diff    = val - prevVal;
        document.getElementById('fgPrev').innerHTML = `Yesterday: <strong>${prevVal}</strong> ${prev.value_classification} <span style="color:${diff>=0?'#22c55e':'#ef4444'}">${diff>=0?'+':''}${diff}</span>`;
      }
    } catch {}
  }

  // ── Sector Heatmap ───────────────────────────────────────────
  async function loadHeatmap() {
    const sectors = ['XLK','XLF','XLE','XLV','XLY','XLP','XLI','XLU','XLB','XLRE'];
    try {
      const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${sectors.join(',')}&fields=symbol,regularMarketChangePercent`;
      const r = await fetch(P + encodeURIComponent(url));
      const w = await r.json();
      const quotes = JSON.parse(w.contents)?.quoteResponse?.result || [];

      quotes.forEach((q: any) => {
        const pct  = q.regularMarketChangePercent ?? 0;
        const cell = document.getElementById(`hm-${q.symbol}`);
        const pEl  = document.getElementById(`hmp-${q.symbol}`);
        if (!cell || !pEl) return;
        cell.classList.remove('skeleton');

        // Color intensity based on % change
        const intensity = Math.min(Math.abs(pct) / 3, 1);
        const bg = pct >= 0
          ? `rgba(34,197,94,${0.1 + intensity * 0.5})`
          : `rgba(239,68,68,${0.1 + intensity * 0.5})`;
        const color = pct >= 0 ? '#22c55e' : '#ef4444';

        cell.style.background    = bg;
        cell.style.borderColor   = color + '40';
        pEl.textContent          = `${pct >= 0 ? '+' : ''}${pct.toFixed(2)}%`;
        pEl.style.color          = color;
      });
    } catch {}
  }

  loadIndices();
  loadMarkets();
  loadNews();
  loadFearGreed();
  loadHeatmap();
  setInterval(() => { loadIndices(); loadMarkets(); loadHeatmap(); }, 60000);
</script>
