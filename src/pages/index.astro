---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await Astro.glob('./blog/*.md').catch(() => []);
const sorted = posts.sort((a: any, b: any) =>
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

const SECTOR_TAGS: Record<string, string> = {
  'AAPL':         '💻 Tech',
  'MSFT':         '💻 Tech',
  'GOOGL':        '💻 Tech',
  'AMZN':         '🛍️ Consumer',
  'TSLA':         '🚗 Auto/EV',
  'META':         '📱 Social',
  'NVDA':         '🤖 Semicon.',
  'JPM':          '💰 Finance',
  'RELIANCE.NS':  '⚡ Energy',
  'TCS.NS':       '💻 Tech',
  'HDFCBANK.NS':  '💰 Finance',
  'INFY.NS':      '💻 Tech',
};
---
<BaseLayout title="Where Smart Money Reads">

  <!-- ── Hero ────────────────────────────────────────── -->
  <section class="hero hero-bg">
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        LIVE MARKET DATA
      </div>
      <h1 class="hero-title">
        Bull Signal.<br />
        <span class="hero-accent">Sharper Moves.</span>
      </h1>
      <p class="hero-desc">
        Live market moves, trending stocks, and investor-focused<br />
        news delivered in one clean, fast dashboard.
      </p>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hs-num">500+</span>
          <span class="hs-label">STOCKS TRACKED</span>
        </div>
        <div class="hs-divider"></div>
        <div class="hero-stat">
          <span class="hs-num">Daily</span>
          <span class="hs-label">NEWS UPDATES</span>
        </div>
        <div class="hs-divider"></div>
        <div class="hero-stat">
          <span class="hs-num">Real-Time</span>
          <span class="hs-label">MARKET DATA</span>
        </div>
      </div>
      <div class="hero-actions">
        <button class="btn-primary" onclick="document.getElementById('markets').scrollIntoView({behavior:'smooth'})">Explore Markets →</button>
        <button class="btn-outline" onclick="document.getElementById('from-ledger').scrollIntoView({behavior:'smooth'})">Daily News</button>
      </div>
    </div>
  </section>

  <!-- ── Indices Bar (US + India) ────────────────────── -->
  <section class="indices-section">
    <div class="indices-grid" id="indicesBar">
      <div class="idx-card skeleton" id="idx-SPY">
        <span class="idx-name">S&P 500</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-QQQ">
        <span class="idx-name">NASDAQ</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-DIA">
        <span class="idx-name">DOW JONES</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="idx-IWM">
        <span class="idx-name">RUSSELL 2000</span>
        <span class="idx-price">—</span>
        <span class="idx-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-NSEI">
        <span class="idx-name">🇮🇳 NIFTY 50</span>
        <span class="idx-price" id="hidx-NSEI-price">—</span>
        <span class="idx-chg"   id="hidx-NSEI-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-BSESN">
        <span class="idx-name">🇮🇳 SENSEX</span>
        <span class="idx-price" id="hidx-BSESN-price">—</span>
        <span class="idx-chg"   id="hidx-BSESN-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-NSEBANK">
        <span class="idx-name">🇮🇳 NIFTY BANK</span>
        <span class="idx-price" id="hidx-NSEBANK-price">—</span>
        <span class="idx-chg"   id="hidx-NSEBANK-chg">—</span>
      </div>
      <div class="idx-card skeleton" id="hidx-MID">
        <span class="idx-name">🇮🇳 NIFTY MIDCAP</span>
        <span class="idx-price" id="hidx-MID-price">—</span>
        <span class="idx-chg"   id="hidx-MID-chg">—</span>
      </div>
    </div>
  </section>

  <!-- ── Today's Markets ─────────────────────────────── -->
  <section class="content-section" id="markets">
    <div class="section-head">
      <h2 class="section-title">Today's Markets</h2>
      <a href="/markets" class="section-more">View all markets →</a>
    </div>
    <div class="markets-grid" id="marketsGrid">
      {['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS'].map((sym) => (
        <a class="mkt-card" id={`mc-${sym}`} href={`/company/${sym.toLowerCase().replace(/\./g,'-')}`}>
          {SECTOR_TAGS[sym] && <span class="mkt-sector-tag">{SECTOR_TAGS[sym]}</span>}
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">{sym.replace('.NS','')}</div>
              <div class="mkt-name" id={`mn-${sym}`}>—</div>
            </div>
            <div class="mkt-badge" id={`mb-${sym}`}>—</div>
          </div>
          <div class="mkt-price" id={`mp-${sym}`}>—</div>
          <div class="mkt-chg" id={`mch-${sym}`}>—</div>
          <canvas class="mkt-chart" id={`chart-${sym}`} height="60"></canvas>
        </a>
      ))}
    </div>
  </section>


  <!-- ── Company Spotlight ─────────────────────────────── -->
  <section class="content-section">
    <div class="section-head">
      <h2 class="section-title">Company Spotlight</h2>
    </div>
    <div class="spotlight-box">
      <div class="spotlight-search">
        <input id="slInput" type="text" class="sl-input" placeholder="Enter ticker symbol (e.g. AAPL)" />
        <button id="slBtn" class="sl-btn">Search</button>
      </div>
      <div id="slResult">
        <p class="sl-hint">Enter a stock ticker above to see company details, live price, and 3-month chart.</p>
      </div>
    </div>
  </section>

  <!-- ── Blog Posts ───────────────────────────────────── -->
  {sorted.length > 0 && (
    <section class="content-section" id="from-ledger">
      <div class="section-head">
        <h2 class="section-title">From the Ledger</h2>
      </div>
      <div class="posts-grid">
        {sorted.map((post: any) => (
          <a href={post.url} class="post-card">
            <div class="pc-date">
              {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </div>
            <h3 class="pc-title">{post.frontmatter.title}</h3>
            <p class="pc-desc">{post.frontmatter.description}</p>
            <span class="pc-read">Read more →</span>
          </a>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<script>
  const FMP_KEY  = 'phURcaq2LTL75pvNfsEL2Lf0GUG8Az2B';
  const FH_KEY   = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
  const PROXY    = 'https://corsproxy.io/?';
  const PROXIES  = [
    'https://corsproxy.io/?',
    'https://api.allorigins.win/raw?url=',
    'https://corsproxy.io/?url=',
  ];

  // ── Cache helpers (instant load on refresh) ──────────────────
  const CACHE_TTL = 90 * 1000; // 90 seconds
  function getCache(key: string) {
    try {
      const c = JSON.parse(localStorage.getItem(key) || 'null');
      if (c && Date.now() - c.ts < CACHE_TTL) return c.data;
    } catch {}
    return null;
  }
  function setCache(key: string, data: any) {
    try { localStorage.setItem(key, JSON.stringify({ ts: Date.now(), data })); } catch {}
  }

  // ── Yahoo Finance fetch with multiple proxy fallbacks ─────────
  async function yfFetch(url: string) {
    for (const px of PROXIES) {
      try {
        const r = await fetch(px + encodeURIComponent(url), { signal: AbortSignal.timeout(6000) });
        if (!r.ok) continue;
        const d = await r.json();
        const result = d?.quoteResponse?.result;
        if (result && result.length > 0) return result;
      } catch {}
    }
    return [];
  }

  async function fetchQuotes(syms: string[]) {
    // 1) FMP batch
    try {
      const r = await fetch(`https://financialmodelingprep.com/api/v3/quote/${syms.join(',')}?apikey=${FMP_KEY}`);
      const d = await r.json();
      if (Array.isArray(d) && d.some((q:any)=>q.price>0))
        return d.map((q:any)=>({symbol:q.symbol,shortName:q.name||q.symbol,regularMarketPrice:q.price,regularMarketChange:q.change??0,regularMarketChangePercent:q.changesPercentage??0,marketCap:q.marketCap,trailingPE:q.pe,fiftyTwoWeekHigh:q.yearHigh,fiftyTwoWeekLow:q.yearLow,averageVolume:q.avgVolume}));
      throw new Error('fmp empty');
    } catch {}
    // 2) Finnhub parallel
    try {
      const res = await Promise.all(syms.map((s:string)=>fetch(`https://finnhub.io/api/v1/quote?symbol=${s}&token=${FH_KEY}`).then((r:Response)=>r.json())));
      const q = syms.map((s:string,i:number)=>({symbol:s,shortName:s,regularMarketPrice:res[i].c||0,regularMarketChange:res[i].d||0,regularMarketChangePercent:res[i].dp||0,marketCap:null,trailingPE:null,fiftyTwoWeekHigh:null,fiftyTwoWeekLow:null,averageVolume:null}));
      if (q.some((x:any)=>x.regularMarketPrice>0)) return q;
      throw new Error('fh empty');
    } catch {}
    // 3) NASDAQ official
    try {
      const res = await Promise.all(syms.map((s:string)=>fetch(PROXY+encodeURIComponent(`https://api.nasdaq.com/api/quote/${s}/info?assetclass=stocks`)).then((r:Response)=>r.json())));
      const q = syms.map((s:string,i:number)=>{const pd=(res[i] as any)?.data?.primaryData||{};return{symbol:s,shortName:s,regularMarketPrice:parseFloat((pd.lastSalePrice||'').replace(/[^0-9.]/g,''))||0,regularMarketChange:parseFloat((pd.netChange||'').replace(/[^0-9.-]/g,''))||0,regularMarketChangePercent:parseFloat((pd.percentageChange||'').replace(/[^0-9.-]/g,''))||0,marketCap:null,trailingPE:null,fiftyTwoWeekHigh:null,fiftyTwoWeekLow:null,averageVolume:null};});
      if (q.some((x:any)=>x.regularMarketPrice>0)) return q;
      throw new Error('nq empty');
    } catch {}
    // 4) Yahoo Finance fallback
    const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${syms.join(',')}&fields=symbol,shortName,regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,fiftyTwoWeekHigh,fiftyTwoWeekLow,averageVolume`;
    const r = await fetch(PROXY+encodeURIComponent(url));
    return (await r.json())?.quoteResponse?.result || [];
  }

  async function yf(syms: string, _fields: string) {
    return fetchQuotes(syms.split(','));
  }

  async function yfChart(sym: string, range = '1mo', interval = '1d') {
    const url = `https://query1.finance.yahoo.com/v8/finance/chart/${sym}?range=${range}&interval=${interval}`;
    const r = await fetch(PROXY + encodeURIComponent(url));
    const w = await r.json();
    return w?.chart?.result?.[0] || null;
  }
  // ── Indices ───────────────────────────────────────────────────────────
  function renderIndex(q: any) {
    const el = document.getElementById(`idx-${q.symbol}`);
    if (!el) return;
    const chg = q.regularMarketChange ?? 0;
    const pct = q.regularMarketChangePercent ?? 0;
    const up  = chg >= 0;
    el.classList.remove('skeleton');
    el.classList.add(up ? 'up' : 'dn');
    el.querySelector('.idx-price')!.textContent = q.regularMarketPrice?.toFixed(2);
    el.querySelector('.idx-chg')!.textContent   = `${up ? '▲' : '▼'} ${Math.abs(pct).toFixed(2)}%`;
  }

  async function loadIndices() {
    const cached = getCache('indices_v2');
    if (cached) cached.forEach(renderIndex);
    try {
      const quotes = await yf('SPY,QQQ,DIA,IWM', '');
      if (quotes.length > 0) { quotes.forEach(renderIndex); setCache('indices_v2', quotes); }
    } catch {}
  }

  // ── Markets Grid ──────────────────────────────────────────────────────
  function renderMarketCard(q: any) {
    const chg   = q.regularMarketChange ?? 0;
    const pct   = q.regularMarketChangePercent ?? 0;
    const up    = chg >= 0;
    const color = up ? '#22c55e' : '#ef4444';
    const isIN  = q.symbol.endsWith('.NS') || q.symbol.endsWith('.BO');
    const curr  = isIN ? '₹' : '$';

    const nameEl  = document.getElementById(`mn-${q.symbol}`);
    const badgeEl = document.getElementById(`mb-${q.symbol}`);
    const priceEl = document.getElementById(`mp-${q.symbol}`);
    const chgEl   = document.getElementById(`mch-${q.symbol}`);
    const card    = document.getElementById(`mc-${q.symbol}`);

    if (nameEl)  nameEl.textContent  = q.shortName || q.longName || '';
    if (priceEl) priceEl.textContent = `${curr}${q.regularMarketPrice?.toFixed(2)}`;
    if (chgEl)   { chgEl.textContent = `${up?'▲':'▼'} ${curr}${Math.abs(chg).toFixed(2)} ${up?'+':''}${pct.toFixed(2)}%`; (chgEl as HTMLElement).style.color = color; }
    if (badgeEl) { badgeEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; badgeEl.classList.add(up?'badge-up':'badge-dn'); }
    if (card)    card.classList.add(up ? 'up' : 'dn');

    yfChart(q.symbol).then(cd => {
      const closes = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
      if (closes.length < 2) return;
      const canvas = document.getElementById(`chart-${q.symbol}`) as HTMLCanvasElement;
      if (!canvas) return;
      new (window as any).Chart(canvas, {
        type: 'line',
        data: { labels: closes.map((_: any, i: number) => i),
          datasets: [{ data: closes, borderColor: color, borderWidth: 2, pointRadius: 0,
            fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }] },
        options: { animation: false, responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: { x: { display: false }, y: { display: false } } }
      });
    }).catch(() => {});
  }

  async function loadMarkets() {
    const allSyms = ['AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','RELIANCE.NS','TCS.NS','HDFCBANK.NS','INFY.NS'];

    // Show cached data instantly
    const cached = getCache('markets_v2');
    if (cached) cached.forEach(renderMarketCard);

    // Fetch all in one Yahoo Finance call (supports both US + IN)
    try {
      const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${allSyms.join(',')}&fields=symbol,shortName,longName,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
      const quotes = await yfFetch(url);
      if (quotes.length > 0) {
        quotes.forEach(renderMarketCard);
        setCache('markets_v2', quotes);
        return;
      }
    } catch {}

    // Fallback: US via fetchQuotes, India via separate yfFetch
    const usSyms = allSyms.filter(s => !s.includes('.'));
    const inSyms = allSyms.filter(s => s.includes('.'));
    try {
      const usQuotes = await yf(usSyms.join(','), '');
      usQuotes.forEach(renderMarketCard);
    } catch {}
    try {
      const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${inSyms.join(',')}&fields=symbol,shortName,longName,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
      const inQuotes = await yfFetch(url);
      inQuotes.forEach(renderMarketCard);
    } catch {}
  }

  // ── News (Reuters RSS) ────────────────────────────────────────────────
  async function loadNews() {
    const list = document.getElementById('newsList');
    if (!list) return;

    const sourceSearchUrl: Record<string, string> = {
      'Reuters':   'https://www.reuters.com/business/',
      'Bloomberg': 'https://www.bloomberg.com/markets',
      'CNBC':      'https://www.cnbc.com/finance/',
      'WSJ':       'https://www.wsj.com/finance',
      'FT':        'https://www.ft.com/markets',
    };

    // Try multiple RSS feeds in order
    const feeds = [
      { url: 'https://feeds.reuters.com/reuters/businessNews', source: 'Reuters' },
      { url: 'https://feeds.bbci.co.uk/news/business/rss.xml', source: 'BBC Business' },
    ];

    for (const feed of feeds) {
      try {
        const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(feed.url)}&count=8`);
        const d = await r.json();
        const items = d?.items || [];
        if (!items.length) continue;
        list.innerHTML = items.map((item: any) => {
          const date = new Date(item.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          const link = item.link || `https://www.google.com/search?q=${encodeURIComponent(item.title)}`;
          return `<a href="${link}" class="news-item" target="_blank" rel="noopener noreferrer">
            <div class="ni-title">${item.title}</div>
            <div class="ni-meta">${item.author || feed.source} · ${date}</div>
          </a>`;
        }).join('');
        return; // success — stop trying feeds
      } catch { continue; }
    }

    // Final fallback — link each item to a Google News search for the headline
    const fallback = [
      ['Fed holds rates as inflation nears 2% target','Reuters'],
      ['S&P 500 hits record high on strong earnings','Bloomberg'],
      ['Apple unveils new AI features at WWDC','CNBC'],
      ['Oil climbs on Middle East supply concerns','Reuters'],
      ['Tesla beats delivery estimates, stock surges 8%','WSJ'],
      ['Goldman Sachs raises S&P 500 year-end target','FT'],
    ];
    list.innerHTML = fallback.map(([t, s]) => {
      const searchUrl = `https://www.google.com/search?q=${encodeURIComponent(t)}&tbm=nws`;
      const sourceUrl = sourceSearchUrl[s] || searchUrl;
      return `<a href="${sourceUrl}" class="news-item" target="_blank" rel="noopener noreferrer">
        <div class="ni-title">${t}</div>
        <div class="ni-meta">${s} · <span style="color:var(--gold);font-size:10px">Read more →</span></div>
      </a>`;
    }).join('');
  }

  // ── Spotlight ─────────────────────────────────────────────────────────
  async function loadSpotlight(sym: string) {
    const result = document.getElementById('slResult');
    if (!result) return;
    result.innerHTML = `<p class="sl-hint">Loading ${sym.toUpperCase()}…</p>`;
    try {
      const s = sym.toUpperCase().trim();
      const [quotes, cd] = await Promise.all([
        yf(s, 'symbol,shortName,longName,regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,fiftyTwoWeekHigh,fiftyTwoWeekLow,averageVolume'),
        yfChart(s)
      ]);
      const q = quotes[0];
      if (!q) throw new Error('not found');
      const chg   = q.regularMarketChange ?? 0;
      const pct   = q.regularMarketChangePercent ?? 0;
      const up    = chg >= 0;
      const color = up ? '#22c55e' : '#ef4444';
      const mcap  = q.marketCap ? (q.marketCap >= 1e12 ? `$${(q.marketCap/1e12).toFixed(2)}T` : `$${(q.marketCap/1e9).toFixed(1)}B`) : '—';

      result.innerHTML = `
        <div class="sl-company">${q.longName || q.shortName || s}</div>
        <div class="sl-price-row">
          <span class="sl-price" style="color:var(--gold)">$${q.regularMarketPrice?.toFixed(2)}</span>
          <span class="sl-delta" style="color:${color}">${up?'▲':'▼'} $${Math.abs(chg).toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>
        </div>
        <div class="sl-stats">
          <div class="sl-stat"><span>Market Cap</span><strong>${mcap}</strong></div>
          <div class="sl-stat"><span>P/E Ratio</span><strong>${q.trailingPE?.toFixed(1) || '—'}</strong></div>
          <div class="sl-stat"><span>52W High</span><strong>$${q.fiftyTwoWeekHigh?.toFixed(2) || '—'}</strong></div>
          <div class="sl-stat"><span>52W Low</span><strong>$${q.fiftyTwoWeekLow?.toFixed(2) || '—'}</strong></div>
          <div class="sl-stat"><span>Avg Volume</span><strong>${q.averageVolume ? (q.averageVolume/1e6).toFixed(1)+'M' : '—'}</strong></div>
        </div>
        <canvas id="slChart" style="height:130px;width:100%"></canvas>
      `;
      const closes     = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
      const timestamps = cd?.timestamp || [];
      if (closes.length > 1) {
        new (window as any).Chart(document.getElementById('slChart') as HTMLCanvasElement, {
          type: 'line',
          data: { labels: timestamps.map((t: number) => new Date(t*1000).toLocaleDateString('en-US',{month:'short',day:'numeric'})),
            datasets: [{ data: closes, borderColor: color, borderWidth: 2, pointRadius: 0,
              fill: true, backgroundColor: up ? 'rgba(34,197,94,0.08)' : 'rgba(239,68,68,0.08)' }] },
          options: { animation: false, responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx: any) => `$${ctx.parsed.y.toFixed(2)}` } } },
            scales: {
              x: { ticks: { color: '#8892a4', maxTicksLimit: 5 }, grid: { color: 'rgba(255,255,255,0.04)' } },
              y: { ticks: { color: '#8892a4', callback: (v: any) => `$${v}` }, grid: { color: 'rgba(255,255,255,0.04)' } }
            } }
        });
      }
    } catch {
      result.innerHTML = `<p class="sl-hint" style="color:#ef4444">Ticker "${sym}" not found. Try AAPL, MSFT, TSLA…</p>`;
    }
  }

  document.getElementById('slBtn')?.addEventListener('click', () => {
    const v = (document.getElementById('slInput') as HTMLInputElement).value;
    if (v.trim()) loadSpotlight(v.trim());
  });
  document.getElementById('slInput')?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      const v = (document.getElementById('slInput') as HTMLInputElement).value;
      if (v.trim()) loadSpotlight(v.trim());
    }
  });

  // ── Fear & Greed ─────────────────────────────────────────────
  async function loadFearGreed() {
    try {
      const r = await fetch('https://api.alternative.me/fng/?limit=2');
      const d = await r.json();
      const cur  = d?.data?.[0];
      const prev = d?.data?.[1];
      if (!cur) throw new Error('empty');
      const val   = parseInt(cur.value);
      const label = cur.value_classification;
      const color = val >= 75 ? '#22c55e' : val >= 55 ? '#84cc16' : val >= 45 ? '#eab308' : val >= 25 ? '#f97316' : '#ef4444';
      document.getElementById('fgValue').textContent = val.toString();
      document.getElementById('fgValue').style.color = color;
      document.getElementById('fgLabel').textContent = label;
      document.getElementById('fgLabel').style.color = color;
      const angle = (val / 100) * 180 - 90;
      const needle = document.getElementById('fgNeedle');
      if (needle) needle.setAttribute('transform', `rotate(${angle} 100 100)`);
      if (prev) {
        const prevVal = parseInt(prev.value);
        const diff = val - prevVal;
        document.getElementById('fgPrev').innerHTML = `Yesterday: <strong>${prevVal}</strong> ${prev.value_classification} <span style="color:${diff>=0?'#22c55e':'#ef4444'}">${diff>=0?'+':''}${diff}</span>`;
      }
    } catch {}
  }

  // ── India Indices ─────────────────────────────────────────────
  function renderIndiaIndex(q: any) {
    const idMap: Record<string,string> = {'^NSEI':'NSEI','^BSESN':'BSESN','^NSEBANK':'NSEBANK','^NIFTYMIDCAP150':'MID'};
    const key = idMap[q.symbol];
    if (!key) return;
    const chg = q.regularMarketChange ?? 0;
    const pct = q.regularMarketChangePercent ?? 0;
    const up  = chg >= 0;
    const color = up ? '#22c55e' : '#ef4444';
    const card = document.getElementById(`hidx-${key}`);
    if (card) { card.classList.remove('skeleton'); card.classList.add(up ? 'up' : 'dn'); }
    const pEl = document.getElementById(`hidx-${key}-price`);
    if (pEl) pEl.textContent = q.regularMarketPrice?.toLocaleString('en-IN', {maximumFractionDigits:2});
    const cEl = document.getElementById(`hidx-${key}-chg`);
    if (cEl) { cEl.textContent = `${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%`; (cEl as HTMLElement).style.color = color; }
  }

  async function loadIndiaIndices() {
    // Show cached instantly
    const cached = getCache('india_idx_v2');
    if (cached) cached.forEach(renderIndiaIndex);

    const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=%5ENSEI,%5EBSESN,%5ENSEBANK,%5ENIFTYMIDCAP150&fields=symbol,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
    const quotes = await yfFetch(url);
    if (quotes.length > 0) {
      quotes.forEach(renderIndiaIndex);
      setCache('india_idx_v2', quotes);
    }
  }

  // ── Hero visual mini ticker ───────────────────────────────────
  async function loadHeroVisual() {
    const syms = ['AAPL','NVDA','TSLA','MSFT','GOOGL'];
    try {
      const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${syms.join(',')}&fields=symbol,regularMarketPrice,regularMarketChangePercent`;
      const res = await fetch(PROXY + encodeURIComponent(url));
      const quotes = (await res.json())?.quoteResponse?.result || [];
      quotes.forEach((q: any) => {
        const pct = q.regularMarketChangePercent ?? 0;
        const up  = pct >= 0;
        const pEl = document.getElementById(`hvp-${q.symbol}`);
        const cEl = document.getElementById(`hvc-${q.symbol}`);
        if (pEl) pEl.textContent = `$${q.regularMarketPrice?.toFixed(2)}`;
        if (cEl) { cEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; (cEl as HTMLElement).style.color = up ? '#22c55e' : '#ef4444'; }
      });
    } catch {}
    // mini NVDA chart
    try {
      const url2 = `https://query1.finance.yahoo.com/v8/finance/chart/NVDA?range=5d&interval=30m`;
      const res2 = await fetch(PROXY + encodeURIComponent(url2));
      const cd   = (await res2.json())?.chart?.result?.[0];
      const closes = cd?.indicators?.quote?.[0]?.close?.filter(Boolean) || [];
      if (closes.length > 2) {
        const up = closes[closes.length-1] >= closes[0];
        const canvas = document.getElementById('hvChart') as HTMLCanvasElement;
        if (canvas) new (window as any).Chart(canvas, {
          type: 'line',
          data: { labels: closes.map((_:any,i:number)=>i), datasets: [{ data: closes, borderColor: up?'#22c55e':'#ef4444', borderWidth: 2, pointRadius: 0, fill: true, backgroundColor: up?'rgba(34,197,94,0.1)':'rgba(239,68,68,0.1)' }] },
          options: { animation: false, responsive: true, maintainAspectRatio: false, plugins: { legend:{display:false}, tooltip:{enabled:false} }, scales: { x:{display:false}, y:{display:false} } }
        });
      }
    } catch {}
  }

  loadIndices();
  loadMarkets();
  loadNews();
  loadFearGreed();
  loadIndiaIndices();
  setInterval(() => { loadIndices(); loadMarkets(); loadIndiaIndices(); }, 60000);
</script>
