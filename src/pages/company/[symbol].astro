<script define:vars={{ sym, curr, isIndian }}>
  let chartInstance = null;
  let _companyData  = null;   // cached company JSON (loaded once, reused for chart + quote)

  const rangeMap = { 30:'1mo', 90:'3mo', 180:'6mo', 365:'1y', 1825:'5y' };

  // Load and cache /data/company/{SYM-NS}.json
  async function getCompanyData() {
    if (_companyData) return _companyData;
    const fname = sym.replace(/\./g, '-');
    try {
      const res = await fetch(`/data/company/${fname}.json`);
      if (!res.ok) return null;
      _companyData = await res.json();
      return _companyData;
    } catch { return null; }
  }

  async function loadQuote() {
    const q = await getCompanyData();
    if (!q || !q.regularMarketPrice) {
      document.getElementById('cpHero').innerHTML = `<div class="cp-sym">${sym.replace('.NS','')}</div><div class="cp-name" style="color:var(--red)">Data unavailable — market data updates twice daily</div>`;
      return;
    }

    const chg = q.regularMarketChange??0, pct = q.regularMarketChangePercent??0;
    const up = chg>=0, color = up?'#22c55e':'#ef4444';
    const high = q.fiftyTwoWeekHigh||0, low = q.fiftyTwoWeekLow||0;
    const priceVsRange = high>low?Math.round(((q.regularMarketPrice-low)/(high-low))*100):50;

    document.getElementById('cpHero').innerHTML = `
      <div class="cp-sym">${sym.replace('.NS','')}</div>
      <div class="cp-name">${q.longName||q.shortName||sym}</div>
      <div style="font-size:12px;color:var(--text-muted);margin-top:4px">NSE · India · ${q.sector||''}`;

    const fmtMcap = q.marketCap>=1e12?`₹${(q.marketCap/1e12).toFixed(2)}T`:q.marketCap>=1e9?`₹${(q.marketCap/1e9).toFixed(1)}B`:q.marketCap>=1e7?`₹${(q.marketCap/1e7).toFixed(0)}Cr`:'—';
    document.getElementById('cpPrice').textContent  = `₹${q.regularMarketPrice?.toLocaleString('en-IN',{maximumFractionDigits:2})||'—'}`;
    document.getElementById('cpChange').innerHTML   = `<span style="color:${color}">${up?'+':''}${chg.toFixed(2)} (${up?'+':''}${pct.toFixed(2)}%)</span>`;
    document.getElementById('cpMcap').textContent   = fmtMcap;
    document.getElementById('cpPE').textContent     = q.trailingPE?q.trailingPE.toFixed(1)+'x':'—';
    document.getElementById('cpHigh').textContent   = high?`₹${high.toFixed(2)}`:'—';
    document.getElementById('cpLow').textContent    = low?`₹${low.toFixed(2)}`:'—';
    document.getElementById('cpVol').textContent    = q.averageVolume?(q.averageVolume/1e6).toFixed(2)+'M':'—';
    document.getElementById('cpBeta').textContent   = q.beta?q.beta.toFixed(2):'—';

    // Fundamentals panel
    document.getElementById('fPE').textContent    = q.trailingPE?q.trailingPE.toFixed(1)+'x':'—';
    document.getElementById('fPB').textContent    = q.priceToBook?q.priceToBook.toFixed(1)+'x':'—';
    document.getElementById('fEPS').textContent   = q.trailingEps?`₹${q.trailingEps.toFixed(1)}`:'—';
    document.getElementById('fROE').textContent   = q.returnOnEquity?`${(q.returnOnEquity*100).toFixed(1)}%`:'—';
    document.getElementById('fDiv').textContent   = q.dividendYield?`${(q.dividendYield).toFixed(2)}%`:'N/A';
    document.getElementById('fMcap').textContent  = fmtMcap;
    document.getElementById('fBeta').textContent  = q.beta?q.beta.toFixed(2):'—';

    if (high>0&&low>0) {
      document.getElementById('f52W').textContent = `${priceVsRange}% of range`;
      document.getElementById('f52WBench').textContent = priceVsRange<35?'Near 52W low — potential value zone':priceVsRange>75?'Near 52W high — check valuation':'Mid-range — neutral';
      const rangeColor = priceVsRange<35?'#22c55e':priceVsRange>75?'#ef4444':'#eab308';
      const f52wEl = document.getElementById('f52W'); if(f52wEl) f52wEl.style.color = rangeColor;
    }

    // Color PE based on valuation
    if (q.trailingPE) {
      const peEl = document.getElementById('fPE');
      if (peEl) peEl.style.color = q.trailingPE<16?'#22c55e':q.trailingPE<26?'#eab308':'#ef4444';
    }
    // Color ROE
    if (q.returnOnEquity) {
      const roe = q.returnOnEquity*100;
      const roeEl = document.getElementById('fROE');
      if (roeEl) roeEl.style.color = roe>20?'#22c55e':roe>12?'#eab308':'#ef4444';
    }

    // About
    document.getElementById('cpAbout').textContent = `${q.longName||q.shortName||sym} is listed on the National Stock Exchange (NSE) of India. ${q.sector?'It operates in the '+q.sector+' sector.':''} Loading additional details…`;
    if (q.website||q.country) {
      document.getElementById('cpAboutMeta').innerHTML = [
        q.website?`<a href="${q.website}" target="_blank" class="cp-meta-link">${q.website.replace('https://','')}</a>`:'',
        `<span>NSE: ${sym.replace('.NS','')}</span>`,
        `<span>India</span>`
      ].filter(Boolean).join('<span class="cp-meta-sep">·</span>');
    }
    fetchWikipedia(q.longName||q.shortName||sym, '');

    // AI Insight
    generateAIInsight(q, priceVsRange, pct);

    // Checklist
    buildChecklist(q, priceVsRange, pct);

    // Ratio tags
    buildRatioTags(q);

    // Chart guide
    buildChartGuide(q, priceVsRange, pct);

    // Show AI box
    const aiBox = document.getElementById('aiInsightBox');
    if (aiBox) aiBox.style.display = 'block';
  }

  function generateAIInsight(q, priceVsRange, pct) {
    const pe      = q.trailingPE||22;
    const roe     = q.returnOnEquity?(q.returnOnEquity*100):15;
    const pb      = q.priceToBook||2;
    const beta    = q.beta||1;

    // Score components (0-100 each)
    const scoreRange  = Math.max(0, 100 - priceVsRange);       // lower in range = better
    const scorePE     = pe<16?90:pe<22?70:pe<28?50:pe<35?30:10;  // lower PE = better
    const scoreROE    = roe>25?95:roe>18?80:roe>12?60:roe>7?40:20; // higher ROE = better
    const scoreMomentum = pct>3?40:pct>0?65:pct>-2?55:pct>-5?40:25; // mild negative ok
    const scoreBeta   = beta<0.8?70:beta<1.2?80:beta<1.6?65:50;

    const total = Math.round((scoreRange*0.25 + scorePE*0.25 + scoreROE*0.2 + scoreMomentum*0.15 + scoreBeta*0.15));
    const score = Math.max(10, Math.min(92, total));

    const signal = score>=70?'🟢 Strong Buy Signal':score>=58?'🟡 Moderate Buy':score>=45?'🟡 Hold / Watch':score>=32?'🔴 Weak — Wait for Dip':'🔴 Avoid — Strong Downtrend';
    const signalColor = score>=65?'#22c55e':score>=45?'#eab308':'#ef4444';
    const entry = score>=65?'Good entry zone — consider buying now or on 3–5% dip':score>=45?'Wait for pull-back to support, or use SIP entry':'Wait for RSI <40 and price stabilization above 52W low';
    const alloc = score>=70?'7–12% of equity portfolio (high conviction)':score>=55?'3–7% (moderate conviction — SIP recommended)':score>=40?'1–3% (speculative, small starter position)':'0% — monitor only, no fresh buying';
    const risk  = beta<0.9?'Low (defensive)':beta<1.2?'Moderate':beta<1.6?'Moderate-High':'High (volatile)';
    const valStatus = pe<16?'Undervalued vs market':pe<22?'Fairly valued':pe<28?'Moderately expensive':'Expensive — growth must justify premium';

    const aiScoreEl = document.getElementById('aiScore'); if(aiScoreEl){aiScoreEl.textContent=score.toString();aiScoreEl.style.color=signalColor;}
    const aiSignalEl = document.getElementById('aiSignal'); if(aiSignalEl){aiSignalEl.textContent=signal;aiSignalEl.style.color=signalColor;}
    document.getElementById('aiEntry').textContent = entry;
    document.getElementById('aiAlloc').textContent = alloc;
    document.getElementById('ai52W').textContent   = `${priceVsRange}% of 52W range`;
    const aiMomEl = document.getElementById('aiMomentum'); if(aiMomEl){aiMomEl.textContent=`${pct>=0?'+':''}${pct.toFixed(2)}% today`;aiMomEl.style.color=pct>=0?'#22c55e':'#ef4444';}
    document.getElementById('aiValuation').textContent = valStatus;
    document.getElementById('aiRisk').textContent = risk;
    document.getElementById('aiDetail').textContent = `Score breakdown: Range position ${scoreRange}/100 · P/E ${scorePE}/100 · ROE ${scoreROE}/100 · Momentum ${scoreMomentum}/100 · Stability ${scoreBeta}/100. ${score>=65?'Technical and fundamental signals align favorably.':score>=45?'Mixed signals — partial entry or SIP is prudent.':'Both momentum and valuation need improvement before entry.'}`;
  }

  function buildChecklist(q, priceVsRange, pct) {
    const checks = [
      { label: 'Price in reasonable range (not near 52W high)', pass: priceVsRange < 80, detail: `Currently at ${priceVsRange}% of 52W range` },
      { label: 'Positive or mild momentum', pass: pct > -3, detail: `Today: ${pct>=0?'+':''}${pct.toFixed(2)}%` },
      { label: 'P/E not grossly expensive', pass: !q.trailingPE || q.trailingPE < 30, detail: q.trailingPE?`P/E: ${q.trailingPE.toFixed(1)}x`:'P/E data unavailable' },
      { label: 'Good ROE (>12%)', pass: !q.returnOnEquity || (q.returnOnEquity*100) > 12, detail: q.returnOnEquity?`ROE: ${(q.returnOnEquity*100).toFixed(1)}%`:'ROE data loading' },
      { label: 'Market cap confirms stability (>₹10,000Cr)', pass: !q.marketCap || q.marketCap > 1e10, detail: q.marketCap?`MCap: ₹${(q.marketCap/1e7).toFixed(0)}Cr`:'MCap loading' },
      { label: 'Listed on NSE (regulated, liquid)', pass: true, detail: `NSE: ${sym.replace('.NS','')} ✓` },
    ];

    const grid = document.getElementById('checklistGrid');
    if (!grid) return;
    grid.innerHTML = checks.map(c => `
      <div class="chk-item ${c.pass?'pass':'fail'}">
        <div class="chk-icon">${c.pass?'✅':'⚠️'}</div>
        <div>
          <div class="chk-label">${c.label}</div>
          <div class="chk-detail">${c.detail}</div>
        </div>
      </div>
    `).join('');

    const passCount = checks.filter(c=>c.pass).length;
    const strategy = passCount>=5?`Strong setup — ${passCount}/6 criteria met. Consider entering now via SIP or lump sum on a 3-5% dip.`:
                     passCount>=3?`Mixed signals — ${passCount}/6 criteria met. Use SIP approach (fixed monthly amount) rather than a large single entry.`:
                     `Weak setup — only ${passCount}/6 criteria met. Advisable to wait for improvements in valuation or momentum before entering.`;
    const stratEl = document.getElementById('investStrategy');
    if (stratEl) stratEl.textContent = strategy;
  }

  function buildRatioTags(q) {
    const peTag = document.getElementById('rePETag');
    if (peTag && q.trailingPE) {
      const pe = q.trailingPE;
      peTag.textContent = pe<16?`${sym.replace('.NS','')} P/E: ${pe.toFixed(1)}x — Cheap vs market`:pe<22?`${sym.replace('.NS','')} P/E: ${pe.toFixed(1)}x — Fairly valued`:pe<30?`${sym.replace('.NS','')} P/E: ${pe.toFixed(1)}x — Premium priced`:`${sym.replace('.NS','')} P/E: ${pe.toFixed(1)}x — Expensive`;
      peTag.style.color = pe<22?'#22c55e':pe<30?'#eab308':'#ef4444';
    } else if (peTag) peTag.textContent = 'P/E data not available for this stock';

    const pbTag = document.getElementById('rePBTag');
    if (pbTag && q.priceToBook) {
      const pb = q.priceToBook;
      pbTag.textContent = pb<1.5?`P/B: ${pb.toFixed(1)}x — Near or below book value`:pb<4?`P/B: ${pb.toFixed(1)}x — Moderate premium to book`:`P/B: ${pb.toFixed(1)}x — High premium (justified for quality businesses)`;
      pbTag.style.color = pb<2?'#22c55e':pb<5?'#eab308':'var(--text-muted)';
    } else if (pbTag) pbTag.textContent = 'P/B data loading';

    const roeTag = document.getElementById('reROETag');
    if (roeTag && q.returnOnEquity) {
      const roe = q.returnOnEquity*100;
      roeTag.textContent = roe>20?`ROE: ${roe.toFixed(1)}% — Excellent capital efficiency`:roe>12?`ROE: ${roe.toFixed(1)}% — Good`:roe>7?`ROE: ${roe.toFixed(1)}% — Below average`:`ROE: ${roe.toFixed(1)}% — Poor — question management efficiency`;
      roeTag.style.color = roe>20?'#22c55e':roe>12?'#eab308':'#ef4444';
    } else if (roeTag) roeTag.textContent = 'ROE data loading';

    const betaTag = document.getElementById('reBetaTag');
    if (betaTag && q.beta) {
      const b = q.beta;
      betaTag.textContent = b<0.8?`Beta: ${b.toFixed(2)} — Defensive stock, moves less than Nifty`:b<1.2?`Beta: ${b.toFixed(2)} — Market-like risk`:b<1.6?`Beta: ${b.toFixed(2)} — Higher volatility than index`:`Beta: ${b.toFixed(2)} — High volatility — use strict stop-losses`;
      betaTag.style.color = b<0.9?'#22c55e':b<1.3?'#eab308':'#ef4444';
    } else if (betaTag) betaTag.textContent = 'Beta loading';
  }

  function buildChartGuide(q, priceVsRange, pct) {
    const ma200El = document.getElementById('cgMA200Status');
    if (ma200El) {
      ma200El.textContent = pct > -5 ? '📈 Price likely above or near 200 DMA — moderate bullish signal' : '📉 Price under pressure — verify 200 DMA on NSE chart';
      ma200El.style.color = pct>-2?'#22c55e':'#ef4444';
    }

    const range52El = document.getElementById('cg52WStatus');
    if (range52El) {
      range52El.textContent = priceVsRange<30?`At ${priceVsRange}% — near 52W low. Value zone, but check if thesis is broken.`:priceVsRange>75?`At ${priceVsRange}% — near 52W high. Momentum play but check valuation.`:`At ${priceVsRange}% of yearly range — mid range, balanced entry.`;
      range52El.style.color = priceVsRange<30?'#22c55e':priceVsRange>80?'#ef4444':'#eab308';
    }

    const trendEl = document.getElementById('cgTrendStatus');
    if (trendEl) {
      trendEl.textContent = pct>=2?'Positive momentum today — uptrend likely continuing':pct>=0?'Mildly positive — stable price action':pct>=-2?'Mildly negative — consolidation phase':' Negative — watch for support levels';
      trendEl.style.color = pct>=0?'#22c55e':'#ef4444';
    }

    const ctxVixEl  = document.getElementById('ctxVix');
    const ctxVixSub = document.getElementById('ctxVixSub');
    // Load VIX from local india-indices.json (no CORS)
    fetch('/data/india-indices.json').then(r=>r.json()).then(d=>{
      const vixEntry = d?.indices?.find(i => i.symbol==='^INDIAVIX');
      if (vixEntry?.regularMarketPrice) {
        const vix = vixEntry.regularMarketPrice;
        if(ctxVixEl){ctxVixEl.textContent=vix.toFixed(2);ctxVixEl.style.color=vix<15?'#22c55e':vix<22?'#eab308':'#ef4444';}
        if(ctxVixSub) ctxVixSub.textContent=vix<15?'Low fear — market calm':vix<22?'Moderate volatility':'High fear — watch carefully';
      }
    }).catch(()=>{});
  }

  async function fetchWikipedia(companyName, fallback) {
    try {
      const attempts = [companyName, companyName.replace(/,?\s*(Inc\.?|Corp\.?|Ltd\.?|plc|Limited|Group|Holdings?|Technologies?|Platforms?|Industries?)\.?$/i,'').trim()];
      for (const name of attempts) {
        const r = await fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(name)}`);
        if (!r.ok) continue;
        const d = await r.json();
        if (d.extract&&d.extract.length>80&&d.type!=='disambiguation') {
          document.getElementById('cpAbout').textContent = d.extract;
          const meta = document.getElementById('cpAboutMeta');
          if (meta&&d.content_urls?.desktop?.page) {
            const wikLink = `<a href="${d.content_urls.desktop.page}" target="_blank" class="cp-meta-link">Wikipedia →</a>`;
            meta.innerHTML = meta.innerHTML ? meta.innerHTML+'<span class="cp-meta-sep">·</span>'+wikLink : wikLink;
          }
          return;
        }
      }
    } catch {}
  }

  async function loadChart(days = 30) {
    const data = await getCompanyData();
    if (!data?.history?.length) return;
    const cutoff  = Date.now()/1000 - days * 86400;
    const filtered = data.history.filter(h => h.t >= cutoff);
    const closes    = filtered.map(h => h.c);
    const timestamps = filtered.map(h => h.t);
    if (!closes.length) return;
    const up = closes[closes.length-1] >= closes[0], color = up ? '#22c55e' : '#ef4444';
    const labels = timestamps.map(t => new Date(t*1000).toLocaleDateString('en-IN',{month:'short',day:'numeric'}));
    if (chartInstance) chartInstance.destroy();
    chartInstance = new Chart(document.getElementById('companyChart'), {
      type:'line',
      data:{labels,datasets:[{data:closes,borderColor:color,borderWidth:2.5,pointRadius:0,fill:true,backgroundColor:up?'rgba(34,197,94,0.07)':'rgba(239,68,68,0.07)'}]},
      options:{animation:false,responsive:true,maintainAspectRatio:false,
        plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`₹${ctx.parsed.y.toFixed(2)}`}}},
        scales:{
          x:{ticks:{color:'#7a8899',maxTicksLimit:8,font:{size:11}},grid:{color:'rgba(255,255,255,0.04)'}},
          y:{ticks:{color:'#7a8899',callback:v=>`₹${v}`,font:{size:11}},grid:{color:'rgba(255,255,255,0.04)'}}
        }}
    });
  }

  async function loadNews() {
    const list = document.getElementById('cpNewsList');
    const symClean = sym.replace('.NS','');
    try {
      const feeds = [
        `https://feeds.finance.yahoo.com/rss/2.0/headline?s=${sym}&region=IN&lang=en-IN`,
        `https://economictimes.indiatimes.com/markets/stocks/news/${symClean.toLowerCase()}/rssfeeds/1977021501.cms`,
      ];
      for (const rss of feeds) {
        const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=8`);
        const d = await r.json();
        const items = d?.items||[];
        if (!items.length) continue;
        list.innerHTML = items.map(item=>{
          const date=new Date(item.pubDate).toLocaleDateString('en-IN',{month:'short',day:'numeric'});
          return `<a href="${item.link}" class="news-item" target="_blank" rel="noopener"><div class="ni-title">${item.title}</div><div class="ni-meta">${item.author||'Economic Times'} · ${date}</div></a>`;
        }).join('');
        return;
      }
    } catch {}
    list.innerHTML = `<div class="news-item"><a href="https://economictimes.indiatimes.com/markets/stocks/news" target="_blank" class="ni-title">View ${symClean} news on Economic Times →</a></div>`;
  }

  document.querySelectorAll('.cpc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cpc-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      loadChart(parseInt(btn.dataset.days));
    });
  });

  // ── Conglomerate data — loaded from /data/conglomerate.json ─────
  async function loadGroupSection() {
    let CONGLOMERATES = {};
    try {
      const res = await fetch('/data/conglomerate.json');
      CONGLOMERATES = await res.json();
    } catch(e) {
      console.warn('Could not load conglomerate.json', e);
    }
    const g = CONGLOMERATES[sym];
    if (!g) return;
    const section = document.getElementById('grpSection');
    if (!section) return;
    section.style.display='block';
    document.getElementById('grpTitle').textContent=g.groupName;
    document.getElementById('grpSubtitle').textContent=g.subtitle||'';
    document.getElementById('grpDivisions').innerHTML=g.divisions.map(d=>`
      <div class="grp-div-card">
        <div class="grp-div-top"><span class="grp-div-icon">${d.icon}</span>
          <div style="flex:1;min-width:0"><div class="grp-div-name">${d.name}</div><span class="grp-div-tag">${d.tag}</span></div>
          <div class="grp-div-stat">${d.stat||''}</div>
        </div>
        <p class="grp-div-desc">${d.desc}</p>
      </div>`).join('');
    if (g.listed?.length) {
      document.getElementById('grpListedWrap').style.display='block';
      document.getElementById('grpStocks').innerHTML=g.listed.map(s=>`
        <a href="/company/${s.sym.toLowerCase().replace(/\./g,'-')}" class="mkt-card">
          <div class="mkt-top"><div><div class="mkt-sym">${s.sym.replace(/\.(NS|BO)$/,'')}</div><div class="mkt-name">${s.name}</div></div><div class="mkt-badge" id="grpb-${s.sym}">—</div></div>
          <div class="mkt-price" id="grpp-${s.sym}">—</div><div class="mkt-chg" id="grpc-${s.sym}">—</div>
        </a>`).join('');
      // Fetch prices from local JSON (no Finnhub)
      try {
        const sRes = await fetch('/data/india-sectors.json');
        const sData = await sRes.json();
        const quotes = sData.quotes || {};
        g.listed.forEach(s => {
          const q = quotes[s.sym] || {};
          if (!q.regularMarketPrice) return;
          const chg=q.regularMarketChange||0, pct=q.regularMarketChangePercent||0, up=chg>=0, color=up?'#22c55e':'#ef4444';
          const pEl=document.getElementById(`grpp-${s.sym}`), bEl=document.getElementById(`grpb-${s.sym}`), cEl=document.getElementById(`grpc-${s.sym}`);
          if(pEl) pEl.textContent=`₹${q.regularMarketPrice.toLocaleString('en-IN',{maximumFractionDigits:2})}`;
          if(bEl){bEl.textContent=`${up?'+':''}${pct.toFixed(2)}%`;bEl.classList.add(up?'badge-up':'badge-dn');}
          if(cEl){cEl.textContent=`${up?'▲':'▼'} ₹${Math.abs(chg).toFixed(2)}`;cEl.style.color=color;}
        });
      } catch {}
    }
  }

  loadQuote();
  loadChart();
  loadNews();
  loadGroupSection();
</script>

<style>
/* ── AI Insight Box ──────────────────────────────── */
.ai-insight-box {
  background: linear-gradient(135deg, rgba(201,168,76,.08), rgba(201,168,76,.04));
  border: 1px solid rgba(201,168,76,.3);
  border-radius: 16px;
  padding: 22px 24px;
  margin: 24px 0;
}
.aib-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.aib-title  { font-size:13px; font-weight:700; color:var(--gold); letter-spacing:.4px; }
.aib-score-wrap { display:flex; align-items:baseline; gap:4px; }
.aib-score  { font-size:2.5rem; font-weight:900; line-height:1; }
.aib-score-label { font-size:13px; color:var(--text-muted); }
.aib-signal { font-size:1.1rem; font-weight:700; margin-bottom:16px; }
.aib-grid   { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:10px; margin-bottom:16px; }
.aib-item   { background:rgba(255,255,255,.04); border-radius:8px; padding:10px 12px; }
.aib-item-label { font-size:10px; font-weight:700; color:var(--text-muted); letter-spacing:.5px; text-transform:uppercase; margin-bottom:4px; }
.aib-item-val   { font-size:13px; font-weight:600; color:#fff; }
.aib-detail { font-size:11px; color:var(--text-muted); border-top:1px solid rgba(255,255,255,.06); padding-top:12px; margin-bottom:8px; }
.aib-disclaimer { font-size:10px; color:var(--text-dim); }

/* ── Fundamentals ────────────────────────────────── */
.fundamentals-section { margin:36px 0; }
.fund-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:12px; }
.fund-card { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:14px 16px; }
.fund-label { font-size:10px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px; }
.fund-value { font-size:1.4rem; font-weight:800; color:#fff; margin-bottom:4px; line-height:1; }
.fund-bench { font-size:10px; color:var(--text-dim); line-height:1.4; }

/* ── Ratios Guide ────────────────────────────────── */
.ratios-section { margin:36px 0; }
.ratios-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:14px; }
.ratio-explain { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:16px 18px; }
.re-name { font-size:13px; font-weight:700; color:#fff; margin-bottom:6px; }
.re-desc { font-size:12px; color:var(--text-muted); line-height:1.6; margin-bottom:8px; }
.re-tag  { font-size:12px; font-weight:600; }

/* ── Checklist ───────────────────────────────────── */
.invest-when-section { margin:36px 0; }
.checklist-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:10px; margin-bottom:16px; }
.chk-item { display:flex; align-items:flex-start; gap:10px; padding:10px 14px; border-radius:10px; border:1px solid var(--border); }
.chk-item.pass { background:rgba(34,197,94,.06); border-color:rgba(34,197,94,.2); }
.chk-item.fail { background:rgba(234,179,8,.06); border-color:rgba(234,179,8,.2); }
.chk-icon  { font-size:16px; flex-shrink:0; margin-top:1px; }
.chk-label { font-size:12px; font-weight:600; color:#fff; margin-bottom:2px; }
.chk-detail{ font-size:11px; color:var(--text-muted); }
.invest-strategy-box { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:16px 18px; }
.isb-title { font-size:11px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
.isb-body  { font-size:13px; color:var(--text-muted); line-height:1.6; }

/* ── Chart Guide ─────────────────────────────────── */
.chart-guide-section { margin:36px 0; }
.chart-guide-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; }
.cg-card  { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:16px; }
.cg-icon  { font-size:20px; margin-bottom:8px; }
.cg-title { font-size:12px; font-weight:700; color:#fff; margin-bottom:6px; }
.cg-desc  { font-size:11px; color:var(--text-muted); line-height:1.5; margin-bottom:8px; }
.cg-status{ font-size:12px; font-weight:600; }

/* ── Market Context ──────────────────────────────── */
.mkt-context-section { margin:36px 0; }
.mkt-ctx-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:12px; }
.mct-card  { background:var(--navy-2); border:1px solid var(--border); border-radius:12px; padding:14px 16px; }
.mct-label { font-size:10px; font-weight:700; letter-spacing:.6px; text-transform:uppercase; color:var(--text-muted); margin-bottom:6px; }
.mct-val   { font-size:1.6rem; font-weight:800; color:#fff; margin-bottom:4px; }
.mct-sub   { font-size:10px; color:var(--text-dim); line-height:1.4; }

/* ── Conglomerate (same as before) ───────────────── */
.grp-subtitle { font-size:13px; color:var(--text-muted); margin:0 0 24px; line-height:1.6; }
.grp-divisions { display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:14px; }
.grp-div-card { background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.07); border-radius:14px; padding:18px 20px; transition:border-color .15s,transform .15s; }
.grp-div-card:hover { border-color:rgba(201,168,76,.3); transform:translateY(-2px); }
.grp-div-top { display:flex; align-items:flex-start; gap:12px; margin-bottom:10px; }
.grp-div-icon { font-size:22px; flex-shrink:0; margin-top:2px; }
.grp-div-name { font-size:13px; font-weight:700; color:#fff; margin-bottom:4px; }
.grp-div-tag  { display:inline-block; background:rgba(201,168,76,.1); color:var(--gold); border:1px solid rgba(201,168,76,.2); border-radius:6px; font-size:10px; font-weight:700; padding:2px 7px; }
.grp-div-stat { margin-left:auto; font-size:11px; font-weight:700; color:var(--gold); white-space:nowrap; padding-left:8px; padding-top:2px; }
.grp-div-desc { font-size:12px; color:#7a8899; line-height:1.65; margin:0; }
</style>
