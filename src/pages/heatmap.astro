    const GAP = 4;
    const items = SECTOR_ETFS.map(sec => ({ ...sec, value: sec.weight }));
    const rects = squarify(items, GAP, GAP, containerW - GAP * 2, containerH - GAP * 2);

    rects.forEach(({ item: sec, x, y, w, h }) => {
      const pct = changeMap[sec.etf] ?? 0;
      const bg  = pctColor(pct);
      const tc  = textColor(pct);
      const showLabel = w > 70 && h > 40;

      const div = document.createElement('div');
      div.className = 'hm-sector-cell';
      div.style.cssText = `
        position:absolute;
        left:${x}px;top:${y}px;width:${w - GAP}px;height:${h - GAP}px;
        background:${bg};color:${tc};
        border:1px solid rgba(0,0,0,.25);border-radius:6px;
        overflow:hidden;cursor:pointer;
        transition:filter .15s;
      `;
      if (showLabel) {
        const fontSize = w > 140 ? '13px' : '11px';
        const pctSize  = w > 140 ? '20px' : '15px';
        div.innerHTML = `
          <div class="hm-sec-name" style="font-size:${fontSize}">${sec.name}</div>
          <div class="hm-sec-pct" style="font-size:${pctSize};color:${pct >= 0 ? '#86efac' : '#fca5a5'}">${pct >= 0 ? '+' : ''}${pct.toFixed(2)}%</div>
          <div class="hm-sec-etf">${sec.etf}</div>
        `;
      } else {
        div.title = `${sec.name} ${pct >= 0 ? '+' : ''}${pct.toFixed(2)}%`;
      }
      div.addEventListener('mouseenter', (e) => { div.style.filter='brightness(1.18)'; showTip(e, null, sec.name, priceMap[sec.etf], pct); });
      div.addEventListener('mouseleave', () => { div.style.filter=''; hideTip(); });
      div.addEventListener('click', () => { window.location.href = `/company/${sec.etf.toLowerCase()}`; });
      map.appendChild(div);
    });
  }

  // ─── Squarified treemap (lightweight, no D3) ──────────────────────────────
  function squarify(items, x, y, w, h) {
    // Sort by value descending
    items = [...items].sort((a, b) => b.value - a.value);
    const total = items.reduce((s, i) => s + i.value, 0);
    const rects = [];
    squarifyRow(items, x, y, w, h, total, rects);
    return rects;
  }

  function squarifyRow(items, x, y, w, h, total, rects) {
    if (!items.length) return;
    if (items.length === 1) {
      rects.push({ item: items[0], x, y, w, h });
      return;
    }

    // Try to find best row
    const isHoriz = w >= h;
    let rowArea = 0;
    let rowItems = [];
    let best = Infinity;

    for (let i = 0; i < items.length; i++) {
      const candidate = items[i];
      const candidateArea = (candidate.value / total) * w * h;
      rowArea += candidateArea;
      rowItems = items.slice(0, i + 1);

      const rowDim = isHoriz ? h : w;
      const rowLen = rowArea / rowDim;
      const worst = Math.max(
        ...rowItems.map(it => {
          const a = (it.value / total) * w * h;
          return Math.max(rowLen / (a / rowLen), (a / rowLen) / rowLen);
        })
      );

      if (worst > best) {
        rowItems = items.slice(0, i);
        rowArea -= candidateArea;
        break;
      }
      best = worst;
    }

    if (!rowItems.length) rowItems = [items[0]];

    const rowAreaTotal = rowItems.reduce((s, it) => s + (it.value / total) * w * h, 0);
    const rowDim = isHoriz ? h : w;
    const rowLen = rowAreaTotal / rowDim;

    let pos = isHoriz ? x : y;
    rowItems.forEach(it => {
      const a = (it.value / total) * w * h;
      const dim = a / rowLen;
      if (isHoriz) {
        rects.push({ item: it, x: x, y: pos, w: rowLen, h: dim });
        pos += dim;
      } else {
        rects.push({ item: it, x: pos, y: y, w: dim, h: rowLen });
        pos += dim;
      }
    });

    const remaining = items.slice(rowItems.length);
    if (remaining.length) {
      const remainArea = remaining.reduce((s, it) => s + it.value, 0);
      if (isHoriz) {
        squarifyRow(remaining, x + rowLen, y, w - rowLen, h, total, rects);
      } else {
        squarifyRow(remaining, x, y + rowLen, w, h - rowLen, total, rects);
      }
    }
  }

  // ─── Render stocks view ────────────────────────────────────────────────────
  function renderStocks() {
    const map = document.getElementById('hmMap');
    map.innerHTML = '';
    map.className = 'hm-map hm-stocks-wrap';
    map.style.position = 'relative';

    // Group by sector
    const sectors = {};
    STOCKS.forEach(s => {
      if (!sectors[s.sector]) sectors[s.sector] = [];
      sectors[s.sector].push({ ...s, value: s.mcap });
    });

    // Layout the sector groups side by side
    const containerW = map.clientWidth || 1100;
    const containerH = Math.max(580, Math.round(containerW * 0.56));
    map.style.height = containerH + 'px';

    // Build top-level items (sectors)
    const totalMcap = STOCKS.reduce((s, st) => s + st.mcap, 0);
    const sectorItems = Object.entries(sectors).map(([name, stocks]) => ({
      name,
      value: stocks.reduce((s, st) => s + st.mcap, 0),
      stocks
    }));

    // Sector-level treemap
    const GAP = 3;
    const sectorRects = squarify(
      sectorItems.map(s => ({ ...s, value: s.value })),
      GAP, GAP, containerW - GAP * 2, containerH - GAP * 2
    );

    sectorRects.forEach(({ item: sector, x: sx, y: sy, w: sw, h: sh }) => {
      // Sector label bar
      const LABEL_H = 20;
      const secDiv = document.createElement('div');
      secDiv.className = 'hm-sec-group';
      secDiv.style.cssText = `left:${sx}px;top:${sy}px;width:${sw}px;height:${sh}px`;

      const label = document.createElement('div');
      label.className = 'hm-sec-group-label';
      label.textContent = sector.name;
      secDiv.appendChild(label);

      // Stock treemap within this sector
      const stockItems = sector.stocks.map(s => ({ ...s, value: s.mcap }));
      const stockRects = squarify(
        stockItems,
        0, LABEL_H, sw - GAP, sh - LABEL_H - GAP
      );

      stockRects.forEach(({ item: stock, x: stx, y: sty, w: stw, h: sth }) => {
        const pct = changeMap[stock.sym] ?? 0;
        const bg  = pctColor(pct);
        const tc  = textColor(pct);
        const showName = stw > 50 && sth > 30;
        const showSym  = stw > 30 && sth > 20;

        const cell = document.createElement('div');
        cell.className = 'hm-stock-cell';
        cell.style.cssText = `left:${stx}px;top:${sty}px;width:${stw - GAP}px;height:${sth - GAP}px;background:${bg};color:${tc}`;

        if (showSym) {
          cell.innerHTML = `
            ${showName ? `<div class="hm-stock-sym" style="font-size:${stw > 80 ? 12 : 10}px">${stock.sym}</div>` : ''}
            ${showName && stw > 60 && sth > 44 ? `<div class="hm-stock-name" style="font-size:9px;opacity:.7">${stock.name}</div>` : ''}
            <div class="hm-stock-pct" style="font-size:${stw > 60 ? 12 : 10}px;color:${pct >= 0 ? '#86efac' : '#fca5a5'}">${pct >= 0 ? '+' : ''}${pct.toFixed(2)}%</div>
          `;
        }

        cell.addEventListener('mouseenter', (e) => showTip(e, stock.sym, stock.name, priceMap[stock.sym], pct, stock.mcap));
        cell.addEventListener('mouseleave', hideTip);
        cell.addEventListener('click', () => {
          window.location.href = `/company/${stock.sym.toLowerCase().replace(/\./g,'-')}`;
        });
        secDiv.appendChild(cell);
      });

      map.appendChild(secDiv);
    });
  }

  // ─── Tooltip ───────────────────────────────────────────────────────────────
  function showTip(e, sym, name, price, pct, mcap) {
    const tip = document.getElementById('hmTip');
    const up  = pct >= 0;
    const mcapStr = mcap ? (mcap >= 1000 ? `$${(mcap/1000).toFixed(1)}T` : `$${mcap.toFixed(0)}B`) : '';
    tip.innerHTML = `
      <div class="tip-name">${name}${sym ? ` <span class="tip-sym">(${sym})</span>` : ''}</div>
      ${price ? `<div class="tip-price">$${parseFloat(price).toFixed(2)}</div>` : ''}
      <div class="tip-pct" style="color:${up ? '#4ade80' : '#f87171'}">${up?'+':''}${pct.toFixed(2)}%</div>
      ${mcapStr ? `<div class="tip-mcap">Market Cap: ${mcapStr}</div>` : ''}
    `;
    tip.style.display = 'block';
    moveTip(e);
  }
  function moveTip(e) {
    const tip = document.getElementById('hmTip');
    tip.style.left = (e.clientX + 14) + 'px';
    tip.style.top  = (e.clientY - 10) + 'px';
  }
  function hideTip() {
    document.getElementById('hmTip').style.display = 'none';
  }
  document.addEventListener('mousemove', (e) => {
    const tip = document.getElementById('hmTip');
    if (tip.style.display === 'block') moveTip(e);
  });

  // ─── Load & render ─────────────────────────────────────────────────────────
  async function load() {
    document.getElementById('hmLoading').style.display = 'flex';
    document.getElementById('hmMap').style.display     = 'none';

    if (currentView === 'sectors') {
      await fetchSectorChanges();
      renderSectors();
    } else {
      await fetchStockChanges();
      renderStocks();
    }

    document.getElementById('hmLoading').style.display = 'none';
    document.getElementById('hmMap').style.display     = 'block';
    document.getElementById('hmUpdated').textContent   = `Updated ${new Date().toLocaleTimeString('en-US', { hour:'2-digit', minute:'2-digit' })}`;
  }

  // ─── View toggle ───────────────────────────────────────────────────────────
  window.setView = function(v) {
    currentView = v;
    document.getElementById('btnSectors').classList.toggle('active', v === 'sectors');
    document.getElementById('btnStocks').classList.toggle('active', v === 'stocks');
    load();
  };

  // ─── Period buttons ────────────────────────────────────────────────────────
  document.querySelectorAll('.hm-period').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.hm-period').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentPeriod = btn.dataset.p;
      load();
    });
  });

  // ─── Init ──────────────────────────────────────────────────────────────────
  load();
  setInterval(load, 90000);
</script>

