---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Market Heat Map">

<section style="margin-top:48px;padding:0 28px;max-width:1240px;margin-left:auto;margin-right:auto">

  <!-- Header -->
  <div class="hm-header">
    <div>
      <h1 class="hm-title">S&amp;P 500 Heat Map</h1>
      <p class="hm-sub">Stocks sized by market cap · colored by performance</p>
    </div>
    <div class="hm-controls">
      <div class="hm-view-toggle">
        <button class="hm-view-btn active" id="btnSectors" onclick="setView('sectors')">Sectors</button>
        <button class="hm-view-btn" id="btnStocks" onclick="setView('stocks')">Stocks</button>
      </div>
      <div class="hm-periods">
        {['1D','5D','1M','3M','6M','YTD','1Y'].map(p => (
          <button class={`hm-period ${p === '1D' ? 'active' : ''}`} data-p={p}>{p}</button>
        ))}
      </div>
    </div>
  </div>

  <!-- Legend row -->
  <div class="hm-legend-row">
    <div class="hm-legend">
      <span class="hm-leg-end" style="color:#ef4444">-5%</span>
      <div class="hm-leg-bar"></div>
      <span class="hm-leg-end" style="color:#22c55e">+5%</span>
      <span class="hm-leg-note">Block size = Market Cap</span>
    </div>
    <span class="hm-updated" id="hmUpdated">—</span>
  </div>

  <!-- Loading -->
  <div id="hmLoading" class="hm-loading">
    <div class="hm-spinner"></div>
    <span>Fetching market data…</span>
  </div>

  <!-- Map area -->
  <div id="hmMap" class="hm-map" style="display:none"></div>

  <!-- Tooltip -->
  <div id="hmTip" class="hm-tip"></div>

</section>

