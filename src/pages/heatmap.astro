  // State
  let currentView   = 'sectors';
  let currentPeriod = '1D';
  let changeMap     = {}; // sym → % change
  let priceMap      = {}; // sym → price
  let allLoaded     = false;

  // ─── Color function ────────────────────────────────────────────────────────
  function pctColor(pct) {
    if (pct >=  5) return '#14532d';
    if (pct >=  3) return '#166534';
    if (pct >=  2) return '#16a34a';
    if (pct >=  1) return '#22c55e';
    if (pct >= 0.3)return '#4ade80';
    if (pct > -0.3)return '#1e2d3d';
    if (pct >= -1) return '#f87171';
    if (pct >= -2) return '#ef4444';
    if (pct >= -3) return '#dc2626';
    if (pct >= -5) return '#b91c1c';
    return '#7f1d1d';
  }
  function textColor(pct) {
    return (pct > 0.3 || pct < -0.3) ? '#fff' : '#94a3b8';
  }

  // ─── Fetch price changes ───────────────────────────────────────────────────
  async function fetchChanges(syms) {
    // Batch into groups of 40
    const batches = [];
    for (let i = 0; i < syms.length; i += 40) batches.push(syms.slice(i, i + 40));

    const results = [];
    await Promise.all(batches.map(async (batch) => {
      try {
        const r = await fetch(`https://financialmodelingprep.com/api/v3/stock-price-change/${batch.join(',')}?apikey=${FMP_KEY}`);
        const d = await r.json();
        if (Array.isArray(d)) results.push(...d);
      } catch {}
    }));

    // Build changeMap
    changeMap = {};
    priceMap  = {};
    results.forEach(item => {
      const key = currentPeriod === 'YTD' ? 'ytd' : currentPeriod;
      changeMap[item.symbol] = item[key] ?? item['1D'] ?? 0;
    });

    // Also fetch current prices from FMP quote
    try {
      const allSyms = syms.join(',');
      const r2 = await fetch(`https://financialmodelingprep.com/api/v3/quote-short/${allSyms}?apikey=${FMP_KEY}`);
      const d2 = await r2.json();
      if (Array.isArray(d2)) d2.forEach(q => { priceMap[q.symbol] = q.price; });
    } catch {}
  }

  async function fetchSectorChanges() {
    const etfSyms = SECTOR_ETFS.map(s => s.etf);
    await fetchChanges(etfSyms);
  }

  async function fetchStockChanges() {
