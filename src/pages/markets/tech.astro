---
import BaseLayout from '../../layouts/BaseLayout.astro';

const STOCKS = [
  { sym: 'AAPL',  name: 'Apple Inc' },
  { sym: 'MSFT',  name: 'Microsoft' },
  { sym: 'GOOGL', name: 'Alphabet' },
  { sym: 'AMZN',  name: 'Amazon' },
  { sym: 'META',  name: 'Meta Platforms' },
  { sym: 'NVDA',  name: 'NVIDIA' },
  { sym: 'TSLA',  name: 'Tesla' },
  { sym: 'AMD',   name: 'AMD' },
  { sym: 'INTC',  name: 'Intel' },
  { sym: 'CRM',   name: 'Salesforce' },
  { sym: 'ORCL',  name: 'Oracle' },
  { sym: 'ADBE',  name: 'Adobe' },
  { sym: 'NFLX',  name: 'Netflix' },
  { sym: 'PYPL',  name: 'PayPal' },
  { sym: 'QCOM',  name: 'Qualcomm' },
];
---
<BaseLayout title="Tech Sector — Market Overview">

  <section class="content-section" style="margin-top:48px">
    <div class="sector-hero tech-sector">
      <div class="sh-icon">💻</div>
      <div>
        <h1 class="sh-title">Technology Sector</h1>
        <p class="sh-sub">Software, semiconductors, internet, and hardware companies</p>
      </div>
      <div class="sh-perf" id="shPerf">
        <span class="shp-label">SECTOR TODAY</span>
        <span class="shp-val" id="sectorChg">Loading…</span>
      </div>
    </div>

    <div class="section-head" style="margin-top:32px">
      <h2 class="section-title">Tech Stocks</h2>
      <span class="section-live">LIVE</span>
    </div>

    <div class="sector-grid" id="sectorGrid">
      {STOCKS.map(s => (
        <a href={`/company/${s.sym.toLowerCase()}`} class="mkt-card sector-card" id={`sc-${s.sym}`}>
          <div class="mkt-top">
            <div>
              <div class="mkt-sym">{s.sym}</div>
              <div class="mkt-name">{s.name}</div>
            </div>
            <div class="mkt-badge" id={`scb-${s.sym}`}>—</div>
          </div>
          <div class="mkt-price" id={`scp-${s.sym}`}>—</div>
          <div class="mkt-chg"   id={`scc-${s.sym}`}>—</div>
          <canvas class="mkt-chart" id={`sct-${s.sym}`} height="50"></canvas>
        </a>
      ))}
    </div>
  </section>

  <!-- Other Sectors -->
  <section class="content-section" style="margin-top:48px">
    <div class="section-head">
      <h2 class="section-title">Other Sectors</h2>
    </div>
    <div class="sector-pills">
      <a href="/markets/finance" class="sector-pill">💰 Finance</a>
      <a href="/markets/energy" class="sector-pill">⚡ Energy</a>
      <a href="/markets/healthcare" class="sector-pill">🏥 Healthcare</a>
      <a href="/markets/consumer" class="sector-pill">🛍️ Consumer</a>
          <a href="/markets/india" class="sector-pill">🇮🇳 India</a>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ stocks: ['AAPL','MSFT','GOOGL','AMZN','META','NVDA','TSLA','AMD','INTC','CRM','ORCL','ADBE','NFLX','PYPL','QCOM'] }}>
  const FMP_KEY  = 'phURcaq2LTL75pvNfsEL2Lf0GUG8Az2B';
  const FH_KEY   = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
  const PROXY    = 'https://corsproxy.io/?';

  async function fetchQuotes(syms) {
    // 1) FMP batch
    try {
      const r = await fetch(`https://financialmodelingprep.com/api/v3/quote/${syms.join(',')}?apikey=${FMP_KEY}`);
      const d = await r.json();
      if (Array.isArray(d) && d.some(q=>q.price>0))
        return d.map(q=>({symbol:q.symbol,shortName:q.name||q.symbol,regularMarketPrice:q.price,regularMarketChange:q.change??0,regularMarketChangePercent:q.changesPercentage??0,marketCap:q.marketCap,trailingPE:q.pe,fiftyTwoWeekHigh:q.yearHigh,fiftyTwoWeekLow:q.yearLow,averageVolume:q.avgVolume}));
      throw new Error('fmp empty');
    } catch {}
    // 2) Finnhub parallel
    try {
      const res = await Promise.all(syms.map(s=>fetch(`https://finnhub.io/api/v1/quote?symbol=${s}&token=${FH_KEY}`).then(r=>r.json())));
      const q = syms.map((s,i)=>({symbol:s,shortName:s,regularMarketPrice:res[i].c||0,regularMarketChange:res[i].d||0,regularMarketChangePercent:res[i].dp||0}));
      if (q.some(x=>x.regularMarketPrice>0)) return q;
      throw new Error('fh empty');
    } catch {}
    // 3) NASDAQ official
    try {
      const res = await Promise.all(syms.map(s=>fetch(PROXY+encodeURIComponent(`https://api.nasdaq.com/api/quote/${s}/info?assetclass=stocks`)).then(r=>r.json())));
      const q = syms.map((s,i)=>{const pd=res[i]?.data?.primaryData||{};return{symbol:s,shortName:s,regularMarketPrice:parseFloat((pd.lastSalePrice||'').replace(/[^0-9.]/g,''))||0,regularMarketChange:parseFloat((pd.netChange||'').replace(/[^0-9.-]/g,''))||0,regularMarketChangePercent:parseFloat((pd.percentageChange||'').replace(/[^0-9.-]/g,''))||0};});
      if (q.some(x=>x.regularMarketPrice>0)) return q;
      throw new Error('nq empty');
    } catch {}
    // 4) Yahoo Finance fallback
    const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${syms.join(',')}&fields=symbol,shortName,regularMarketPrice,regularMarketChange,regularMarketChangePercent,marketCap,trailingPE,fiftyTwoWeekHigh,fiftyTwoWeekLow,averageVolume`;
    const r = await fetch(PROXY+encodeURIComponent(url));
    return (await r.json())?.quoteResponse?.result || [];
  }

  async function loadSector() {
    const quotes = await fetchQuotes(stocks);
    let totalPct = 0;
    quotes.forEach(q => {
      const chg = q.regularMarketChange ?? 0;
      const pct = q.regularMarketChangePercent ?? 0;
      const up  = chg >= 0;
      const color = up ? '#22c55e' : '#ef4444';
      totalPct += pct;
      const card = document.getElementById(`sc-${q.symbol}`);
      if (card) card.classList.add(up ? 'up' : 'dn');
      const bEl = document.getElementById(`scb-${q.symbol}`);
      if (bEl) { bEl.textContent = `${up?'+':''}${pct.toFixed(2)}%`; bEl.classList.add(up?'badge-up':'badge-dn'); }
      const pEl = document.getElementById(`scp-${q.symbol}`);
      if (pEl) pEl.textContent = `$${q.regularMarketPrice?.toFixed(2)}`;
      const cEl = document.getElementById(`scc-${q.symbol}`);
      if (cEl) { cEl.textContent = `${up?'▲':'▼'} $${Math.abs(chg).toFixed(2)}`; cEl.style.color = color; }
    });
    const avg = totalPct / (quotes.length || 1);
    const el  = document.getElementById('sectorChg');
    if (el) { el.textContent = `${avg>=0?'+':''}${avg.toFixed(2)}%`; el.style.color = avg>=0?'#22c55e':'#ef4444'; }
  }

  loadSector();
</script>