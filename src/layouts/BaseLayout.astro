---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | The Business Ledger</title>
    <meta name="description" content="Insights on business, finance, and entrepreneurship. Your daily edge in the world of commerce." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <!-- Ticker Bar -->
    <div class="ticker-bar">
      <div class="ticker-label">LIVE</div>
      <div class="ticker-track" id="tickerTrack">
        <span class="ticker-loading">Loading markets…</span>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="nav-logo-icon">▲</span>
          The Business Ledger
        </a>
        <div class="nav-links">
          <a href="/">Markets</a>
          <a href="/">News</a>
          <a href="/about">About</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="nav-logo-icon">▲</span>
          The Business Ledger
        </div>
        <p class="footer-tagline">Your daily edge in the world of commerce.</p>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/about">About</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} The Business Ledger. Market data for informational purposes only.</p>
      </div>
    </footer>

    <script>
      // ── Ticker Bar ──────────────────────────────────────────────────
      const TICKER_SYMBOLS = ['SPY','QQQ','DIA','AAPL','MSFT','GOOGL','AMZN','TSLA','META','NVDA','JPM','GS','BRK-B','XOM','WMT'];

      async function loadTicker() {
        const track = document.getElementById('tickerTrack');
        if (!track) return;
        try {
          const symbols = TICKER_SYMBOLS.join(',');
          const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${symbols}&fields=symbol,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
          const res = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(url)}`);
          const wrapper = await res.json();
          const data = JSON.parse(wrapper.contents);
          const quotes = data?.quoteResponse?.result || [];
          if (!quotes.length) throw new Error('no data');

          const items = quotes.map(q => {
            const chg = q.regularMarketChange ?? 0;
            const pct = q.regularMarketChangePercent ?? 0;
            const sign = chg >= 0 ? '+' : '';
            const cls  = chg >= 0 ? 'up' : 'dn';
            return `<span class="ticker-item ${cls}"><strong>${q.symbol}</strong> $${q.regularMarketPrice?.toFixed(2)} <span>${sign}${pct.toFixed(2)}%</span></span>`;
          }).join('<span class="ticker-sep">|</span>');

          // Duplicate for seamless loop
          track.innerHTML = items + '<span class="ticker-sep">·</span>' + items;
        } catch {
          track.innerHTML = TICKER_SYMBOLS.map(s => `<span class="ticker-item"><strong>${s}</strong> —</span>`).join('<span class="ticker-sep">|</span>');
        }
      }

      loadTicker();
      setInterval(loadTicker, 60000);
    </script>
  </body>
</html>
