---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | The Business Ledger</title>
    <meta name="description" content="Professional-grade market intelligence for people who'd rather invest than guess." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Business Ledger" />
    <meta property="og:title" content={`${title} | The Business Ledger`} />
    <meta property="og:description" content="Professional-grade market intelligence for people who'd rather invest than guess." />
    <meta property="og:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <meta property="og:url" content="https://thebusinessledger.theapurva.com" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | The Business Ledger`} />
    <meta name="twitter:description" content="Professional-grade market intelligence for people who'd rather invest than guess." />
    <meta name="twitter:image" content="https://thebusinessledger.theapurva.com/og-image.png" />
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link rel="stylesheet" href="/styles/global.css" />
    <style>
      /* News ticker positioning — inline to avoid CDN cache delay */
      .news-bar {
        top: 36px !important;
        z-index: 998 !important;
        background: #0d1420 !important;
        border-bottom: 1px solid rgba(201,168,76,0.15) !important;
      }
      body { padding-top: 128px !important; }
      .site-nav { top: 72px !important; }
    </style>
  </head>
  <body>

    <!-- ── Market Ticker Bar ───────────────────── -->
    <div class="ticker-bar">
      <div class="ticker-track" id="tickerTrack">
        <span class="ticker-placeholder">Loading market data…</span>
      </div>
    </div>

    <!-- ── News Ticker Bar ──────────────────────── -->
    <div class="ticker-bar news-bar">
      <div class="ticker-track" id="newsTickerTrack">
        <span class="ticker-placeholder">Loading headlines…</span>
      </div>
    </div>

    <!-- ── Navigation ──────────────────────────── -->
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">
          <div class="nav-logo-box">BL</div>
          <div class="nav-brand-text">
            <span class="nav-brand-name">The Business Ledger</span>
            <span class="nav-brand-sub">WHERE SMART MONEY READS</span>
          </div>
        </a>
        <div class="nav-links">
          <a href="/" class="nav-link active">Home</a>
          <a href="/markets/tech" class="nav-link">Markets</a>
          <a href="/earnings-calendar" class="nav-link">Earnings</a>
          <a href="/economic-calendar" class="nav-link">Economy</a>
          <a href="/ipo-tracker" class="nav-link">IPOs</a>
          <a href="/tools" class="nav-link">Tools</a>
          <a href="/about" class="nav-link">About</a>
        </div>
        <div class="nav-search">
          <span class="nav-search-icon">🔍</span>
          <input type="text" class="nav-search-input" placeholder="Search companies, news…" />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="nav-logo-box">BL</div>
            <div class="nav-brand-text">
              <span class="nav-brand-name">The Business Ledger</span>
              <span class="nav-brand-sub">WHERE SMART MONEY READS</span>
            </div>
          </div>
          <p class="footer-desc">Professional-grade market intelligence for people who'd rather invest than guess.</p>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">&copy; {new Date().getFullYear()} The Business Ledger. Market data for informational purposes only.</p>
          <div class="footer-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // ── Ticker ────────────────────────────────────────────────────────
      const TICKER_SYMS = ['NVDA','META','TSLA','JPM','AAPL','MSFT','GOOGL','AMZN','SPY','QQQ','GS','NFLX','AMD','INTC','BRK-B'];
      const FH_KEY = 'd81lae1r01qrojfc2i2gd81lae1r01qrojfc2i30';
      const P = 'https://corsproxy.io/?';

      async function loadTicker() {
        const track = document.getElementById('tickerTrack');
        if (!track) return;
        try {
          let quotes = [];
          try {
            const fhRes = await Promise.all(TICKER_SYMS.map(s =>
              fetch(`https://finnhub.io/api/v1/quote?symbol=${s}&token=${FH_KEY}`).then(r => r.json())
            ));
            const fhQ = TICKER_SYMS.map((s, i) => ({
              symbol: s,
              regularMarketPrice: fhRes[i].c,
              regularMarketChange: fhRes[i].d,
              regularMarketChangePercent: fhRes[i].dp
            }));
            if (fhQ.some(q => q.regularMarketPrice > 0)) quotes = fhQ;
            else throw new Error('empty');
          } catch {
            const url = `https://query1.finance.yahoo.com/v7/finance/quote?symbols=${TICKER_SYMS.join(',')}&fields=symbol,regularMarketPrice,regularMarketChange,regularMarketChangePercent`;
            const res = await fetch(P + encodeURIComponent(url));
            const w   = await res.json();
            quotes = w?.quoteResponse?.result || [];
          }
          if (!quotes.length) throw new Error('empty');

          const html = quotes.map(q => {
            const chg = q.regularMarketChange ?? 0;
            const pct = q.regularMarketChangePercent ?? 0;
            const up  = chg >= 0;
            const cls = up ? 'up' : 'dn';
            return `<span class="ti ${cls}"><strong>${q.symbol}</strong> $${q.regularMarketPrice?.toFixed(2)} <em>${up?'▲':'▼'} ${Math.abs(pct).toFixed(2)}%</em></span>`;
          }).join('<span class="ti-sep">·</span>');

          track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
        } catch {
          track.innerHTML = TICKER_SYMS.map(s => `<span class="ti"><strong>${s}</strong> —</span>`).join('');
        }
      }

      loadTicker();
      setInterval(loadTicker, 60000);

      // ── News Ticker ───────────────────────────────────────────────────
      async function loadNewsTicker() {
        const track = document.getElementById('newsTickerTrack');
        if (!track) return;
        const feeds = [
          'https://feeds.reuters.com/reuters/businessNews',
          'https://feeds.bbci.co.uk/news/business/rss.xml',
        ];
        for (const rss of feeds) {
          try {
            const r = await fetch(`https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rss)}&count=12`);
            const d = await r.json();
            const items = (d?.items || []).filter((i: any) => i.title);
            if (!items.length) continue;
            const html = items.map((item: any) =>
              `<a class="ti" style="text-decoration:none;cursor:pointer;" href="${item.link}" target="_blank" rel="noopener noreferrer"><strong>◆</strong> ${item.title}</a>`
            ).join('<span class="ti-sep">·</span>');
            track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
            return;
          } catch { continue; }
        }
        const fallback = [
          ['Fed holds rates as inflation nears 2% target','https://www.reuters.com/business/'],
          ['S&P 500 hits record high on strong earnings','https://www.bloomberg.com/markets'],
          ['Apple unveils new AI features at WWDC','https://www.cnbc.com/finance/'],
          ['Oil climbs on Middle East supply concerns','https://www.reuters.com/business/'],
          ['Tesla beats delivery estimates, stock surges 8%','https://www.wsj.com/finance'],
          ['Goldman Sachs raises S&P 500 year-end target','https://www.ft.com/markets'],
        ];
        const html = fallback.map(([t,u]) =>
          `<a class="ti" style="text-decoration:none;cursor:pointer;" href="${u}" target="_blank" rel="noopener noreferrer"><strong>◆</strong> ${t}</a>`
        ).join('<span class="ti-sep">·</span>');
        track.innerHTML = html + '<span class="ti-sep" style="padding:0 20px"> </span>' + html;
      }

      loadNewsTicker();
      setInterval(loadNewsTicker, 300000);
    </script>
  </body>
</html>
